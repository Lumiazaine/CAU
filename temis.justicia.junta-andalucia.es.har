          "content": {
            "size": 43220,
            "mimeType": "text/html",
            "compression": -59,
            "text": " \r\n \r\n\r\n\r\n\r\n\r\n\r\n<!DOCTYPE HTML PUBLIC \"-//W3C//DTD HTML 4.01 Transitional//EN\">\r\n\r\n\r\n<HTML>\r\n\r\n<head>\r\n\t<title>Adriano Comun</title>\r\n\t<LINK href=\"css/general.css\" rel=\"stylesheet\" type=\"text/css\">\r\n\r\n\t<!-- [Biblioteca de Actualizacion de Condiciones de Busqueda] -->\r\n\t<script language=\"javascript\" src=\"js/JS_condiciones.js\"></script>\r\n\t<!-- [Biblioteca de CheckBox] -->\r\n\t<script language=\"javascript\" src=\"js/JS_checkbox.js\"></script>\r\n\t<!-- [Biblioteca de Ordenacion por columnas de una tabla] -->\r\n\t<script language=\"javascript\" src=\"js/JS_ordenar.js\"></script>\r\n\t<script language=\"javascript\" src=\"js/popup.js\"></script>\r\n\t<script language=\"javascript\" src=\"js/JS_validacion.js\"></script>\t\r\n\t\r\n\t<script language=\"Javascript\" type=\"text/javascript\">\r\n\t\t\r\n\t// -------------------------------------------------------------------\r\n\t// -------------------------------------------------------------------\r\n\t// ACCIONES POSIBLES DEL FORMULARIO\r\n\t// -------------------------------------------------------------------\r\n\t// -------------------------------------------------------------------\r\n\t\r\n\tfunction selecciona(obj)\r\n\t{\r\n\t\tif(obj.checked == true)\t\tobj.value = '1';\r\n\t\telse\t\t\t\t\t\tobj.value = '0';\t\r\n\t}\r\n\t\r\n\t\r\n\tfunction estableceChecks()\r\n\t{\r\n\t\tvar f = document.forms[0];\r\n\t\tchequea(f.organismoHijo);\r\n\t}\r\n\t\r\n\tfunction estableceChecksListado(){\r\n\t\r\n\t\tvar f = document.forms[1];\r\n\t\tchequea(f.listadoOrganismoHijo);\r\n\t}\r\n\t\t\r\n\tfunction chequea(obj)\r\n\t{\r\n\t\tif(obj.value == '1')\t\tobj.checked = true;\r\n\t\telse\t\t\t\t\t\tobj.checked = false;\r\n\t}\t\r\n\t\t\r\n\tfunction actualizar()\r\n\t{\r\n\t\tvar f= document.forms[0];\r\n\t\tf.partidoJudicial.value = f.codigoPartidoJudicial.options[f.codigoPartidoJudicial.selectedIndex].text;\r\n\t\tf.municipios.value = f.codigoMunicipioPart.options[f.codigoMunicipioPart.selectedIndex].text;\r\n\t\tf.accion.value = \"actualizar\";\r\n\t\tf.submit();\r\n\t}\r\n\r\n\tfunction ocultarConsulta()\r\n\t{\r\n\t\tvar f= document.forms[0];\r\n\t\tf.busquedaAbierta.value = \"false\";\r\n\t\tf.organismo.value = f.codigoOrganismo.options[f.codigoOrganismo.selectedIndex].text;\r\n\t\tvar obj = document.getElementById(\"consulta\");\r\n\t\tobj.style.display =\"none\";\r\n\t}\r\n\t\t\r\n\tfunction consultaMunicipios()\r\n\t{\r\n\t\tvar f = document.forms[0];\r\n\t\tvar random_num = (Math.round((Math.random()*1000000000000)+1));\r\n\t\t\t\t\t\r\n\t\tvar url = \"UsuarioEleccionMunicipio.do?nocache=\" + random_num;\r\n\r\n\t\tCreateWnd(url, 500, 580, true);\r\n\t}\r\n\t\r\n\r\n\t\r\n\tfunction listadoUsuarios()\r\n\t{\r\n\t\tvar f = document.forms[0];\r\n\t\tf.accion.value =\"listado\";\r\n\t\tf.submit();\r\n\t}\r\n\t\r\n\tfunction chequearUsuarioActivo()\r\n\t{\r\n\t  var f1 = document.forms[1];\r\n\t  f1.activos.checked = \"true\";\r\n\t}\r\n\t\r\n\tfunction funcionariosOrganismo()\r\n\t{\r\n\t\tvar f = document.forms[0];\r\n\t\twindow.location.href = 'servlet/InformeServlet?codigo=' +  f.codigoOrganismo.value + '&descripcion=' +  f.organismo.value;\r\n\t}\r\n\r\n\t\r\n\tfunction limpiar()\r\n\t{\r\n\t\tdocument.forms[0].accion.value = \"limpiar\";\r\n\t\tdocument.forms[0].submit();\r\n\t}\r\n\r\n\tfunction limpiarDos()\r\n\t{\r\n\t\tvar usuarios = \"[com.ius.temis.beans.Usuario@1b4341d9]\";\r\n\t\tvar mensaje = \"false\";\r\n\t\r\n\t\tvar f = document.forms[1];\r\n\t\tf.nombre.value=\"\";\r\n\t\tf.apellidos.value=\"\";\r\n\t\tf.usuario.value=\"\";\r\n\t\tif (f.noResultados.value==\"true\" || f.mayor.value==\"true\")\r\n\t\t\tmensaje=\"true\";\r\n\t\tif (usuarios!=\"null\" || mensaje==\"true\")\r\n\t\t{\r\n\t\t    //f.accion.value=\"limpiar\";\r\n\t\t\tf.accion.value=\"limpiarDos\";\r\n\t\t\tf.submit();\t\r\n\t\t}\r\n\t}\r\n\t\r\n\tfunction limpiarListado(){\r\n\t\tvar f = document.forms[1];\r\n\t\tif((f.codigoProvincia.value==\"\" || f.codigoProvincia.value==\"null\")\r\n\t\t\t&& (f.codigoInformePartidoJudicial.value==\"\" || f.codigoInformePartidoJudicial.value==\"null\"))\r\n\t\t{\r\n\t\tf.codigoEstado.value = \"N\";\r\n\t\tf.codigoCargo.value = \"\";\r\n\t\tf.codigoProvincia.value = \"\";\r\n\t\tf.codigoInformePartidoJudicial.value = \"\";\r\n\t\tf.codigoInformeMunicipio.value = \"\";\r\n\t\tf.codigoInformeOrganismo.value = \"\";\r\n\t\tf.codigoInformeTipoOrganismo.value = \"\";\r\n\t\t}\r\n\t\telse\r\n\t\t{\r\n\t\t\tf.codigoInformeTipoOrganismo.value = \"\";\r\n\t\t    f.accion.value=\"limpiarListado\";\r\n\t\t    f.target=\"\";\r\n\t\t\tf.submit();\r\n\t\t}\r\n\t\t\r\n\t}\r\n\r\n  \tfunction cerrar(f)\r\n\t{\r\n\t\tdocument.forms[0].accion.value = \"cerrar\";\r\n\t\tdocument.forms[0].submit();\r\n\t}\r\n\t\r\n\tfunction buscar()\r\n\t{\r\n\t\tvar f = document.forms[0];\r\n\t\tvar codPartidoJudicial = f.codigoPartidoJudicial.options[f.codigoPartidoJudicial.selectedIndex].value;\r\n\t\tvar codigoMunicipioPart = f.codigoMunicipioPart.options[f.codigoMunicipioPart.selectedIndex].value;\r\n\t\tvar codOrganismo = f.codigoOrganismo.options[f.codigoOrganismo.selectedIndex].value;\r\n\t    var codTipoOrganismo = f.codigoTipoOrganismo.options[f.codigoTipoOrganismo.selectedIndex].value;\r\n\t\t\r\n\t\tif ( codPartidoJudicial != \"\" &&  codigoMunicipioPart != \"\" && codOrganismo != \"\" && codTipoOrganismo!=\"\")\r\n\t\t{\r\n\t\t    f.accion.value = \"buscar_uno\";\r\n\t\t\tf.submit();\r\n\t\t \t\r\n\t\t}\r\n\t\telse\r\n\t\t{\r\n\t\t\talert('Debe seleccionar un Partido Judicial, un Municipio, un tipo de Organismo y un Organismo para realizar la busqueda.');\r\n\t\t}\r\n\t}\r\n\r\n\tfunction buscarDos()\r\n\t{\r\n\t\tvar f = document.forms[1];\r\n\t\tif (validarCampos(f, true))\r\n\t\t{\r\n\t\t\r\n\t\t\tf.accion.value = \"buscar_dos\";\r\n\t\t\tf.target=\"\";\r\n\t\t\tf.submit();\r\n\t\t}\r\n\t}\r\n\t\r\n\tfunction mostrarInforme()\r\n\t{\r\n\t  var f = document.forms[1];\r\n\r\n\t  if((f.valorEstado.value == \"\" || f.valorEstado.value == \"-- Seleccione el Estado\" )&& f.codigoCargo.value == \"\" && f.codigoProvincia.value == \"\"\r\n\t    && f.codigoInformePartidoJudicial.value == \"\" && f.codigoInformeMunicipio.value == \"\" \r\n\t    && f.codigoOrganismo.value == \"\"){\r\n\t    \r\n\t    alert('Debe seleccionar al menos una opcion de consulta');\r\n\t  \r\n\t  }else{\r\n\t    if(f.codigoInformeOrganismo.value ==\"\" && f.listadoOrganismoHijo.value == \"1\"){\r\n\t    \r\n\t    \talert('La opcion \"Incluir organismos hijos\" no debe ser chequeada sin haber seleccionado previamente un Organismo');\r\n\t    \r\n\t    }else{\r\n\t  \t\t\r\n\t  \t\twin=window.open('','myWin','toolbar=no, menubar=no, location=no, resizable=yes, status=yes, scrollbars=yes'); \r\n\t\t\tf.target='myWin';\r\n\t\t\twin.document.write(\r\n        \t\"<HEAD><TITLE>Listado de Usuarios</TITLE></HEAD>\");\r\n\t\t\tf.accion.value =\"mostrar_informe\";\r\n\t  \t\tf.submit();\r\n\t  \t}\r\n\t  }\t\r\n\t}\r\n\t\r\n  \t\r\n   function baja()\r\n\t{\r\n\t   \tvar f = document.forms[0];\r\n\t    var aValores = devuelveChecksMarcados(f.codigoUsuario);\r\n\t\t\r\n\t\tif(aValores != \"\")\r\n\t\t{    \r\n  \t\t\t//Obtengo el codigo del Cargo\r\n\t\t    obtenerCodigoCargo();\r\n\t\t\tobtenerPuestoPrincipal();\r\n\t\t\t    var idUsuarios = \"\";\r\n\t\t\t \r\n\t\t\t  \tfor(var i = 0; i < aValores.length; i++)\r\n\t\t\t    {\r\n\t\t\t    \tidUsuarios += aValores[i] + \"#\";\r\n\t\t\t    }\r\n\t\t\t    f.accion.value = \"baja\";\r\n\t\t    \tf.codigosUsuarios.value = idUsuarios;\r\n\t\t    \tf.submit();\r\n\t\t\t }\r\n\t\t\t else\r\n\t\t\t {\r\n\t\t    \talert('Debe seleccionar al menos un usuario');\r\n\t\t\t }\r\n\t\t}\r\n\t\t\r\n\t\tfunction obtenerPuestoPrincipal(){\r\n\t\t\r\n\t\t\tvar f = document.forms[0];\r\n\t\t\tvar aValor = devuelveCheckMarcado(f.codigoUsuario);\r\n\t\t\t//Caso en el que hay un solo elemento\r\n\t\t\tif(aValor == -1){\r\n\t\t\t\r\n\t\t\t\taValor = 0;\r\n\t\t\t\r\n\t\t\t}\r\n\t\t\tvar obj = document.getElementById(\"PuestoPrincipal\"+aValor);\r\n\t\t\t//Obtengo el html correspondiente\r\n\t\t\t//var informacion = obj.innerHTML;\r\n\t\t\t\r\n\t\t\t// TEMIS-75 INICIO\r\n\t\t\t//var posValue = informacion.indexOf('value');\r\n\t\t\t//var posType = informacion.indexOf('type');\r\n\t\t\t//var posType = informacion.indexOf(' ', posValue);\r\n\t\t\t//var resultado = informacion.substring(posValue + 7, posType - 2);\r\n\t\t\t//var resultado = informacion.substring(posValue + 7, posType - 1);\r\n\t\t\t// TEMIS-75 FIN\r\n\t\t\t\r\n\t\t\t/* TEMIS-75: Comentado código\r\n\t\t\t//Subcadena desde el valor del cargo \r\n\t\t\tvar subStr = informacion.substring(25, informacion.length);\r\n\t\t\t//hasta el primer espacio\r\n\t\t\tvar posicionEspacio = subStr.indexOf(' ');\r\n\t\t\tvar entero = parseInt(posicionEspacio);\r\n\t\t\tvar resultado = subStr.substring(0,entero);\r\n\t\t\t*/\r\n\t\t\t//Vuelco el valor a la variable codigoCargo\r\n\r\n\t\t\t//f.valorPuestoPrincipal.value = resultado;\r\n\t\t\t\r\n\t\t\t//TEMIS-88\r\n\t\t\t//alert(obj.value);\r\n\t\t\tf.valorPuestoPrincipal.value = obj.value;\r\n\t\t\t\r\n\t\t}\r\n\t\t\r\n\t\tfunction obtenerCodigoCargo(){\r\n\t\t\r\n\t\t\tvar f = document.forms[0];\r\n\t\t\tvar aValor = devuelveCheckMarcado(f.codigoUsuario);\r\n\t\t\t//Caso en el que hay un solo elemento\r\n\t\t\tif(aValor == -1){\r\n\t\t\t\r\n\t\t\t\taValor = 0;\r\n\t\t\t\r\n\t\t\t}\r\n\t\t\tvar obj = document.getElementById(\"CodigoDelCargo\"+aValor);\r\n\t\t\t//Obtengo el html correspondiente\r\n\t\t\tvar informacion = obj.innerHTML;\r\n\t\t\t//Subcadena desde el valor del cargo \r\n\t\t\tvar subStr = informacion.substring(25, informacion.length);\r\n\t\t\t//hasta el primer espacio\r\n\t\t\tvar posicionEspacio = subStr.indexOf(' ');\r\n\t\t\tvar entero = parseInt(posicionEspacio);\r\n\t\t\tvar resultado = subStr.substring(0,entero);\r\n\t\t\t//Vuelco el valor a la variable codigoCargo\r\n\t\t\tf.valorCargo.value = resultado;\r\n\t\t\r\n\t\t}\r\n\r\n\r\n\tfunction activarDos()\r\n\t{\r\n\t   \tvar f = document.forms[1];\r\n\t   \tvar aValores = devuelveChecksMarcados(f.codigoUsuario);\r\n\t\t\r\n\t\tif(aValores != \"\")\r\n\t\t{    \r\n  \t\t\t\r\n\t\t\t    var idUsuarios = \"\";\r\n\t\t\t \r\n\t\t\t  \tfor(var i = 0; i < aValores.length; i++)\r\n\t\t\t    {\r\n\t\t\t    \tidUsuarios += aValores[i] + \"#\";\r\n\t\t\t    }\r\n\t\t\t    f.accion.value = \"activar\";\r\n\t\t    \tf.codigosUsuarios.value = idUsuarios;\r\n\t\t    \tf.submit();\r\n\t\t\t  \r\n\t\t\t }\r\n\t\t\t else\r\n\t\t\t {\r\n\t\t    \talert('Debe seleccionar al menos un usuario');\r\n\t\t\t }\r\n\t\t}\r\n\t\t\r\n\tfunction nuevo()\r\n\t\t{\r\n\t\t\tvar f = document.forms[0];\r\n\t\t\tif((f.codigoPartidoJudicial.value != \"\") && (f.codigoMunicipioPart.value != \"\") && (f.codigoOrganismo.value != \"\")&& (f.codigoTipoOrganismo.value != \"\"))\r\n\t\t\t{\r\n\t\t\t\tf.municipios.value = f.codigoMunicipioPart.options[f.codigoMunicipioPart.selectedIndex].text;\r\n\t\t\t\tf.tipoOrganismo.value = f.codigoTipoOrganismo.options[f.codigoTipoOrganismo.selectedIndex].text;\r\n\t\t\t\tf.accion.value = \"nuevo\";\r\n\t\t\t\tf.submit();\r\n\t\t\t}\r\n\t\t\telse\r\n\t\t\t{\r\n\t\t\t\talert('Debe introducir un Partido Judicial, un Municipio, un tipo de Organismo y un Organismo');\r\n\t\t\t}\t\t\r\n\t\t}\r\n\t\t\r\n\t\tfunction modificar()\r\n\t\t{\r\n\t       var f = document.forms[0];\r\n\t\t\tvar valor = devuelveValorCheckMarcado(f.codigoUsuario);\t\t\t\r\n\t\t  if(valor != \"\")\r\n\t\t   { \r\n\t\t    //Obtengo el codigo del Cargo\r\n\t\t     obtenerCodigoCargo();\r\n\t\t     obtenerPuestoPrincipal();\r\n\t\t     f.municipios.value = f.codigoMunicipioPart.options[f.codigoMunicipioPart.selectedIndex].text;\r\n\t\t     f.tipoOrganismo.value = f.codigoTipoOrganismo.options[f.codigoTipoOrganismo.selectedIndex].text;\r\n\t\t     f.accion.value=\"modificar\";\r\n\t\t     f.submit();\r\n\t\t   }\r\n\t\t   else\r\n\t\t   {\r\n\t\t    alert('Debe seleccionar un usuario');\r\n\t\t   }\r\n\t\t}\r\n\t\r\n\t\tfunction modificarDos()\r\n\t\t{\r\n\t       f = document.forms[1];\r\n\t      var valor = devuelveValorCheckMarcado(f.codigoUsuario);\r\n\t\t   \r\n\t\t   if(valor != \"\")\r\n\t\t   {\r\n\t\t     f.accion.value = \"modificarDos\";\r\n\t\t     f.submit();\r\n\t\t   }\r\n\t\t   else\r\n\t\t   {\r\n\t\t    \talert('Debe seleccionar un usuario');\r\n\t\t   }\r\n\t\t}\r\n\t\t\r\n\t\tfunction consultar()\r\n\t\t{\r\n\t       f = document.forms[1];\r\n\t      var valor = devuelveValorCheckMarcado(f.codigoUsuario);\r\n\t\t   \r\n\t\t   if(valor != \"\")\r\n\t\t   {\r\n\t\t   \t f.action.value = \"UsuarioConsultar.do\"\r\n\t\t     f.accion.value = \"consultar\";\r\n\t\t     f.submit();\r\n\t\t   }\r\n\t\t   else\r\n\t\t   {\r\n\t\t    \talert('Debe seleccionar un usuario');\r\n\t\t   }\r\n\t\t}\r\n\t\t\r\n\t\tfunction cambioDestino()\r\n\t\t{\r\n\t       var f = document.forms[0];\r\n\t       \r\n     \t   var valor = devuelveValorCheckMarcado(f.codigoUsuario);\r\n     \t   if(valor != \"\")\r\n\t\t   { \r\n\t\t   \t//Obtengo el codigo del Cargo\r\n\t\t     obtenerCodigoCargo();\r\n\t\t     obtenerPuestoPrincipal();\t\t   \r\n\t\t     f.accion.value=\"cambioDestino\";\r\n\t\t     f.submit();\r\n\t\t   }\r\n\t\t   else\r\n\t\t   {\r\n\t\t    alert('Debe seleccionar un usuario');\r\n\t\t   }\r\n\t\t}\r\n\t\t\r\n\t\t\r\n\t\t function listadoUsuarios(){\r\n\t\t    var f = document.forms[0];\r\n\t\t   \r\n\t\t    f.accion.value = \"listar\";\r\n\t\t  \t//Ocultamos la bÃƒÂºsqueda de usuarios y visualizamos el listado\r\n\t\t  \tvar objConsultaUsuarios = document.getElementById(\"TablaConsultaUsuarios\");\r\n\t\t  \tobjConsultaUsuarios.style.display = \"none\";\r\n\t\t  \tf.submit();\r\n\t\t}\r\n\t\t\r\n\t\tfunction ocultarTablaConsultaUsuarios(){\r\n\t\t  var objConsultaUsuarios = document.getElementById(\"TablaConsultaUsuarios\");\r\n\t\t  objConsultaUsuarios.style.display = \"none\";\r\n\t\t  \r\n\t\t}\r\n\t\t\r\n\t\tfunction ocultarListadoUsuarios(){\r\n\t\t  var objListadoUsuarios = document.getElementById(\"TablaListadoUsuarios\");\r\n\t\t  var objConsultaUsuarios = document.getElementById(\"TablaConsultaUsuarios\");\r\n\t\t  objListadoUsuarios.style.display = \"none\";\r\n\t\t  objConsultaUsuarios.style.display = \"block\";\r\n\t\t  \r\n\t\t}\r\n\t\t\r\n\t\tfunction obtenerCargo()\r\n\t\t{\r\n\t\t\tvar f = document.forms[1];\r\n\t\t\tf.cargo.value = f.codigoCargo.options[f.codigoCargo.selectedIndex].text;\r\n        }\r\n        \r\n      \r\n\t\t\r\n\t\tfunction obtenerEstado()\r\n\t\t{\r\n\t\t\tvar f = document.forms[1];\r\n\t\t\tf.valorEstado.value = f.codigoEstado.options[f.codigoEstado.selectedIndex].text;\r\n\t\t}\r\n\t\t\r\n\t\t\r\n\t\tfunction refrescarProvincias()\r\n\t\t{\r\n\t\t\tvar f = document.forms[1];\r\n\t\t\tf.provincia.value = f.codigoProvincia.options[f.codigoProvincia.selectedIndex].text;\r\n\t\t\tf.target = \"\";\r\n\t\t\tf.accion.value = \"listar\";\r\n\t\t\tf.submit(); \r\n\t\t}\r\n\t   \r\n\t   function refrescarPartidos()\r\n\t\t{\r\n\t\t\tvar f = document.forms[1];\r\n\t\t\tf.informePartidoJudicial.value = f.codigoInformePartidoJudicial.options[f.codigoInformePartidoJudicial.selectedIndex].text;\r\n\t\t\tf.target=\"\";\r\n\t\t\tf.accion.value = \"listar\";\r\n\t\t\tf.submit(); \r\n\t   }  \r\n\t   \r\n\t   function refrescarMunicipios()\r\n\t\t{\r\n\t\t\tvar f = document.forms[1];\r\n\t\t\tf.informeMunicipio.value = f.codigoInformeMunicipio.options[f.codigoInformeMunicipio.selectedIndex].text;\r\n\t\t\tf.target=\"\";\r\n\t\t\tf.accion.value = \"listar\";\r\n\t\t\tf.submit();\r\n\t\t}\r\n\t   function refrescarTipoOrganismo(){\r\n\t\t   \r\n\t\t   var f = document.forms[1];\r\n\t\t\tf.informeTipoOrganismo.value = f.codigoInformeTipoOrganismo.options[f.codigoInformeTipoOrganismo.selectedIndex].text;\t\t\t\r\n\t\t\tf.target=\"\";\r\n\t\t\tf.accion.value = \"listar\";\r\n\t\t\tf.submit(); \r\n\t\t   \r\n\t   }\r\n\t\t\r\n\t\tfunction obtenerOrganismo()\r\n\t\t{\r\n\t\t\tvar f = document.forms[0];\r\n\t\t\tf.organismo.value = f.codigoOrganismo.options[f.codigoOrganismo.selectedIndex].text;\r\n\t\t}\r\n\t\r\n    \t\r\n    \t\r\n    function anularPrimeraBusqueda()\r\n\t{\r\n\t   \tvar f = document.forms[0];\r\n\t   \r\n\t\tvar aValores = devuelveChecksMarcados(f.codigoUsuario);\r\n\t\t\r\n\t\tif(aValores != \"\")\r\n\t\t{   \r\n\t\t//Obtengo el codigo del Cargo\r\n\t\t   obtenerCodigoCargo();\r\n\t\t   obtenerPuestoPrincipal();\r\n\t\t\r\n  \t\t\tif (confirm('¿Está seguro de eliminar de la aplicación los usuarios seleccionados?'))\r\n\t\t\t{\r\n\t\t\t    var idUsuarios = \"\";\r\n\t\t\t \r\n\t\t\t  \tfor(var i = 0; i < aValores.length; i++)\r\n\t\t\t    {\r\n\t\t\t    \tidUsuarios += aValores[i] + \"#\";\r\n\t\t\t    }\r\n\t\t\t    f.accion.value = \"anular\";\r\n\t\t    \tf.codigosUsuarios.value = idUsuarios;\r\n\t\t    \tf.submit();\r\n\t\t\t  \t}\r\n\t\t\t }\r\n\t\t\t else\r\n\t\t\t {\r\n\t\t    \talert('Debe seleccionar al menos un usuario');\r\n\t\t\t }\r\n\t\t}\r\n\tfunction anularSegundaBusqueda()\r\n\t{\r\n\t   \tvar f = document.forms[1];\r\n\t\t\r\n\t\tvar aValores = devuelveChecksMarcados(f.codigoUsuario);\r\n\t\tif(aValores != \"\")\r\n\t\t{    \r\n  \t\t\tif (confirm('¿Está seguro de eliminar de la aplicación los usuarios seleccionados?'))\r\n\t\t\t{\r\n\t\t\t    var idUsuarios = \"\";\r\n\t\t\t \r\n\t\t\t  \tfor(var i = 0; i < aValores.length; i++)\r\n\t\t\t    {\r\n\t\t\t    \tidUsuarios += aValores[i] + \"#\";\r\n\t\t\t    }\r\n\t\t\t    f.accion.value = \"anularSegundaBusqueda\";\r\n\t\t    \tf.codigosUsuarios.value = idUsuarios;\r\n\t\t    \tf.submit();\r\n\t\t\t  \t}\r\n\t\t\t }\r\n\t\t\t else\r\n\t\t\t {\r\n\t\t    \talert('Debe seleccionar al menos un usuario');\r\n\t\t\t }\r\n\t\t}\r\n\t\t\r\n\t\t\r\n\t\tfunction muestraNIF()\r\n\t\t{\r\n\t\t//Selecciono Otros\r\n\t\tif(document.forms[1].codigoDocumento.value == \"O\"){\r\n\t\t   var objNif = document.getElementById(\"NIF\");\r\n\t\t   var objOtros = document.getElementById(\"OTROS\");\r\n\t\t   objNif.style.display = \"none\";\r\n\t\t   objOtros.style.display = \"block\";\r\n\t\t   //Quito el valor del DNI\r\n\t\t   document.forms[1].dni.value= \"\";\r\n\t\t   //document.forms[1].otro.value= \"\";\r\n\t\t\r\n\t\t//Selecciono NIF\r\n\t\t }else if(document.forms[1].codigoDocumento.value == \"D\"){\r\n\t\t    var objNif = document.getElementById(\"NIF\");\r\n\t\t    var objOtros = document.getElementById(\"OTROS\");\r\n\t\t    objNif.style.display = \"block\";\r\n\t\t    objOtros.style.display = \"none\";\r\n\t\t     //Quito el valor del otro\r\n\t\t    document.forms[1].otro.value= \"\";\r\n\t\t    //document.forms[1].dni.value= \"\";\r\n\t\t\r\n\t\t }\r\n\t\t //No selecciono nada\r\n\t\t else{\r\n\t\t   var objNif = document.getElementById(\"NIF\");\r\n\t\t    var objOtros = document.getElementById(\"OTROS\");\r\n\t\t    objNif.style.display = \"none\";\r\n\t\t    objOtros.style.display = \"none\";\r\n\t\t    //Quito el valor del dni y de otro\r\n\t\t    document.forms[1].otro.value= \"\";\r\n\t\t    document.forms[1].dni.value= \"\";\r\n\t\t }    \r\n\t\t}\r\n\t\t\r\n\tfunction validarCampos(f,v) \r\n\t{\t\t\r\n\t\tif (v)\r\n\t\t{\r\n\t\t\tvar aCampos = new Array();\r\n\t\t\tif(f.codigoDocumento.value == \"D\"){\r\n\t\t\t\taCampos[aCampos.length] = [f.dni, \"NIF\", ['dni', null, null]];\r\n\t\t\t}\r\n\t\t\tif(f.codigoDocumento.value == \"O\"){\r\n\t\t\t\taCampos[aCampos.length] = [f.otro, \"Documento\", ['otro', null, null]];\r\n\t\t\t}\t\r\n\t\t\t\r\n\t\t\treturn validateRequiredFields(f, aCampos);\r\n\t\t\r\n\t\t}\r\n\t\telse \r\n\t\t{\r\n\t\t\treturn true;\r\n\t\t}\t\r\n\t}\r\n\t\r\n\tfunction mostrarPerfiles()\r\n\t\t{\r\n\t      var f = document.forms[0];\r\n\t\t  var valor = devuelveValorCheckMarcado(f.codigoUsuario);\r\n\t\t  if(valor != \"\")\r\n\t\t   { \r\n\t\t    //Obtengo el codigo del Cargo\r\n\t\t     obtenerCodigoCargo();\r\n\t\t     obtenerPuestoPrincipal();\r\n\t\t     f.accion.value=\"mostrarPerfiles\";\r\n\t\t     f.submit();\r\n\t\t   }\r\n\t\t   else\r\n\t\t   {\r\n\t\t    alert('Debe seleccionar un usuario');\r\n\t\t   }\r\n\t\t}\r\n\t\t\r\n\t\tfunction mostrarPerfilesBusquedaDos()\r\n\t\t{\r\n\t\t  var f = document.forms[1];\r\n\t\t  var valor = devuelveValorCheckMarcado(f.codigoUsuario);\r\n\t\t  if(valor != \"\")\r\n\t\t   { \r\n\t\t    //Obtengo el codigo del Cargo\r\n\t\t     f.accion.value=\"mostrarPerfilesDos\";\r\n\t\t     f.submit();\r\n\t\t   }\r\n\t\t   else\r\n\t\t   {\r\n\t\t    alert('Debe seleccionar un usuario');\r\n\t\t   }\r\n\t\t}\r\n\t\t\r\n\t\tdocument.onkeypress=function(e){\r\n\t\t\tvar num = e?e.keyCode:event.keyCode;\r\n\t\t\tif(num == 13)\r\n\t\t\t\t{\t\t\t\t\t\r\n\t\t\t\t\tbuscarDos();\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t\r\n\t\tfunction buscarBaja()\r\n\t\t{\r\n\t\t\tvar f = document.forms[1];\r\n\t\t\t\r\n\t\t\tvar usuario = f.usuario.value;\r\n\t\t\tvar nombre = f.nombre.value;\r\n\t\t\tvar apellidos = f.apellidos.value;\r\n\t\t\tvar documento = f.codigoDocumento.options[f.codigoDocumento.selectedIndex].value;\r\n\t\t\t\r\n\t\t\tif (usuario == \"\" && nombre == \"\" &&  apellidos == \"\" && documento == \"\")\r\n\t\t\t{\t\t\t\r\n\t\t\t\talert('Debe seleccionar un Usuario, un Nombre, unos Apellidos o un Documento para realizar la busqueda.');\r\n\t\t\t}\r\n\t\t\telse\r\n\t\t\t{\r\n\t\t\t\tif (validarCampos(f, true))\r\n\t\t\t\t{\r\n\t\t\t\t\tif (confirm('Se buscarán usuarios dados de baja en todas las provincias. Si encuentra un usuario al que desee ' \r\n\t\t\t\t\t\t\t+'cambiar de destino, márquelo y luego pulse el botón \\'Modificar\\' y luego el botón \\'Cambio de Destino\\''))\r\n\t\t\t\t\t{\t\t\t\t\r\n\t\t\t\t\t\tf.accion.value = \"buscar_baja\";\r\n\t\t\t\t\t\tf.target=\"\";\r\n\t\t\t\t\t\tf.submit();\r\n\t\t\t\t\t}\t\t\r\n\t\t\t\t}\r\n\t\t\t}\t\t\t\r\n\t\t}\r\n\t\t\r\n\t</script>\r\n\t\r\n</head>\r\n\r\n<body onload=\"javascript:estableceChecks();estableceChecksListado();muestraNIF()\">\r\n    <!-- [COMIENZO CABECERA COMUN] -->\r\n\t<!DOCTYPE HTML PUBLIC \"-//W3C//DTD HTML 4.01 Transitional//EN\">\r\n\r\n\r\n<HEAD>\r\n<LINK href=\"css/menu.css\" rel=\"stylesheet\" type=\"text/css\">\r\n</HEAD>\r\n<table border=\"0\" width=\"778\" cellpadding=\"0\" cellspacing=\"0\" border=0>\r\n\t<tr>\r\n\t\t<td colspan=\"2\">\r\n\t\t\t<table border=\"0\" cellspacing=0 cellpadding=0 bgcolor=#EEEDEB width=741>\r\n\t\t\t\t<tr>\r\n\t\t\t\t\t<td width=\"175\"><img src=\"img/cabecera/01.gif\"></td>\r\n\t\t\t\t\t<td width=\"295\"><img src=\"img/cabecera/02.gif\"></td>\r\n\t\t\t\t\t<td width=\"230\"><img src=\"img/cabecera/03.gif\"></td>\t\t\t\t\t\r\n\t\t\t\t\t<td width=\"33\"><img src=\"img/cabecera/04.gif\"></td>\r\n\t\t\t\t</tr>\r\n\t\t\t</table>\r\n\t\t</td>\r\n\t</tr>\r\n</table>\r\n\r\n\t<!-- [FIN CABECERA COMUN] -->\r\n\t<!-- tabla 1 -->\r\n\t<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"780\">\r\n\t<tr>\r\n\t\t<td width=\"110\" valign=\"top\">\r\n\t\t\t<!-- [COMIENZO MENU] -->\r\n\t\t\t\r\n\r\n\r\n<!DOCTYPE HTML PUBLIC \"-//W3C//DTD HTML 4.01 Transitional//EN\">\r\n\r\n<div id=\"menu\">\r\n\r\n\t\r\n\r\n\t\r\n\t<!-- [COMIENZO CATEGORIA DE MENU] -->\r\n\t<div class=\"Categoria\">\r\n\t\tMantenimiento\r\n\t</div>\r\n\r\n\t\r\n\t\t<div class=\"Accion\"><span class=\"Flechita\">&#187;&nbsp;</span><a href=\"AplicacionConsulta.do\">Aplicaciones</a></div>\r\n\t\r\n\r\n\t\r\n\t\t<div class=\"Accion\"><span class=\"Flechita\">&#187;&nbsp;</span><a href=\"CargoConsulta.do\">Cargos</a></div>\r\n\t\r\n\r\n\t\r\n\t\t<div class=\"Accion\"><span class=\"Flechita\">&#187;&nbsp;</span><a href=\"ComunidadConsulta.do\">Comunidades</a></div>\r\n\t\r\n\r\n\t\r\n\t\t<div class=\"Accion\"><span class=\"Flechita\">&#187;&nbsp;</span><a href=\"CuerpoConsulta.do\">Cuerpos</a></div>\r\n\t\t\r\n\r\n\t\r\n\r\n\t\r\n\t\t<div class=\"Accion\"><span class=\"Flechita\">&#187;&nbsp;</span><a href=\"DominioConsulta.do\">Dominios</a></div>\r\n\t\r\n\r\n\t\r\n\t\t<div class=\"Accion\"><span cl