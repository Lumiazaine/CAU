          "content": {
            "size": 2874,
            "mimeType": "text/javascript",
            "text": "function actualizarCondiciones(p_Campo, p_Posicion, FILAS, aCampos, f)\r\n{\r\n\tif(p_Campo != \"\")\r\n\t{\r\n\t\t//--------------------------------------------------------\r\n\t\t// \tEscribimos algo en el campo\r\n\t\t//\tEl funcionamiento es el siguiente:\r\n\t\t//\t\t- Ver si Existe un valor anterior\r\n\t\t//\t\t\t- Existe: Ponemos \"Y\"\r\n\t\t//\t\t\t- No Existe: Nada\r\n\t\t//\t\t- Buscar el siguiente\r\n\t\t//\t\t\t- Si existe: Ponerle un \"AND\"\r\n\t\t\r\n\t\tif (p_Posicion >1 && existeValorAnterior(p_Posicion, aCampos, f))\r\n\t\t{\r\n\t\t\tif(eval('f.cboCondicion' + p_Posicion + '.selectedIndex == 0'))\r\n\t\t\t{\r\n\t\t\t\teval('f.cboCondicion' + p_Posicion + '.selectedIndex = 1');\r\n\t\t\t}\r\n\t\t}\t\t\r\n\t\t\r\n\t\tvar posicionSiguiente = buscaSiguienteElemento(p_Posicion, aCampos, f, FILAS);\r\n\t\t\t\r\n\t\tif (posicionSiguiente != -1)\r\n\t\t{\r\n\t\t\tif (eval('f.cboCondicion' + posicionSiguiente + '.selectedIndex == 0'))\r\n\t\t\t{\r\n\t\t\t\teval('f.cboCondicion' + posicionSiguiente + '.selectedIndex = 1');\r\n\t\t\t}\r\n\t\t}\t\t\r\n\t\t//--------------------------------------------------------\r\n\t}\r\n\telse\r\n\t{\r\n\t\t//--------------------------------------------------------\r\n\t\t// \tBorramos un elemento con valor\r\n\t\t//\tEl funcionamiento es el siguiente:\r\n\t\t//\t\t1.- Quitamos su Condicion (si la tiene)\r\n\t\t//\t\t2.- Ver si Existe un valor anterior\r\n\t\t//\t\t\t2.1.- Existe: Fin\r\n\t\t//\t\t\t2.2.- No Existe: \r\n\t\t//\t\t\t\t2.2.1.- Buscar valor posterior siguiente\r\n\t\t//\t\t\t\t\t2.2.1.1.- Existe: Quitamos su condición\r\n\t\t//\t\t\t\t\t2.2.1.2.- No Existe: Fin\r\n\t\t\r\n\t\tif(p_Posicion >1)\r\n\t\t\t// 1.- Siempre que no sea el primer campo de búsuqeda.\r\n\t\t\teval('f.cboCondicion' + p_Posicion + '.selectedIndex = 0');\r\n\t\t\r\n\t\t// 2.-\r\n\t\tif ( (p_Posicion == 1) || (p_Posicion >1 && !existeValorAnterior(p_Posicion, aCampos, f)) )\r\n\t\t{\r\n\t\t\t// 2.2.1.-\r\n\t\t\tvar posicionSiguiente = buscaSiguienteElemento(p_Posicion, aCampos, f, FILAS);\r\n\t\t\t\r\n\t\t\t// 2.2.1.1.-\r\n\t\t\tif (posicionSiguiente != -1)\r\n\t\t\t{\r\n\t\t\t\teval('f.cboCondicion' + posicionSiguiente + '.selectedIndex = 0');\r\n\t\t\t}\r\n\t\t}\r\n\t\t//--------------------------------------------------------\r\n\t}\r\n}\r\n\r\nfunction existeValorAnterior(p_Posicion, aCampos, f)\r\n{\r\n\tvar bExito = false;\r\n\t\r\n\tfor( var i=p_Posicion-1 ; i>0 ; i-- )\r\n\t{\r\n\t\tif(compruebaTieneValor(i, aCampos, f))\r\n\t\t{\r\n\t\t\tbExito = true;\r\n\t\t}\r\n\t}\r\n\t\r\n\treturn bExito;\r\n}\r\n\r\nfunction buscaSiguienteElemento(p_Posicion, aCampos, f, FILAS)\r\n{\r\n\tfor( var i=p_Posicion+1 ; i <= FILAS ; i++ )\r\n\t{\r\n\t\tif(compruebaTieneValor(i, aCampos, f))\r\n\t\t{\r\n\t\t\treturn i;\r\n\t\t}\r\n\t}\r\n\t\r\n\treturn -1;\r\n}\r\n\r\nfunction compruebaTieneValor(i, aCampos, f)\r\n{\r\n\t// Comprobamos los campos de Texto\r\n\tif(aCampos[i-1].substring(0,3) == \"txt\")\r\n\t{\r\n\t\tif(eval('f.' + aCampos[i-1] + '.value') != \"\")\r\n\t\t{\r\n\t\t\treturn true;\r\n\t\t}\r\n\t}\r\n\t//Comprobamos el combo\r\n\telse if (aCampos[i-1].substring(0,3) == \"cbo\")\r\n\t{\r\n\t\tif(eval('f.' + aCampos[i-1] + '.options[f.' + aCampos[i-1] + '.selectedIndex].value') != \"\")\r\n\t\t{\r\n\t\t\treturn true;\r\n\t\t}\r\n\t}\r\n\r\n\treturn false;\r\n}\r\n\r\n\r\n"
          },
