          "content": {
            "size": 2748,
            "mimeType": "text/javascript",
            "text": "// Funcion que compureba que tengamos un unico checkbox marcado \r\n// y devuelve la posicion del check marcado\r\nfunction devuelveCheckMarcado(checkbox)\r\n{\r\n\tvar f = document.forms[0];\r\n\t\r\n\tvar resultado = -100;\r\n\tvar bEntra = false;\r\n\r\n\t// Vemos si tiene marcada una fila o mas\r\n\tif(checkbox[0])\r\n\t{\r\n\t\tfor (var i=0; i < checkbox.length; i++)\r\n\t\t{\r\n\t\t\tif (checkbox[i].checked==true)\r\n\t\t\t{\r\n\t\t\t\tresultado = i;\r\n\t\t\t\t\r\n\t\t\t\tif (bEntra)\r\n\t\t\t\t{\r\n\t\t\t\t\talert('Tiene marcadas mas de una opcion.');\r\n\t\t\t\t\t\r\n\t\t\t\t\tresultado = -100;\r\n\t\t\t\t\t\t\r\n\t\t\t\t\tbreak;\r\n\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t\tbEntra = true;\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n\telse\r\n\t{\r\n\t\t\r\n\t\tif(checkbox.checked)\r\n\t\t{\t\t\r\n\t\t\tresultado = -1;\r\n\t\t}\r\n\t\t\r\n\t}\r\n\t\r\n\treturn resultado;\r\n}\r\n\r\n\r\n// Funcion que devuelve el valor del check marcado\r\nfunction devuelveValorCheckMarcado(checkbox)\r\n{\r\n\tvar posicion = devuelveCheckMarcado(checkbox);\r\n\t\r\n\tvar resultado = \"\";\r\n\t\r\n\tif (posicion != -100)\r\n\t{\t\r\n\t\tif (posicion == -1)\r\n\t\t\tresultado = checkbox.value;\r\n\t\telse\r\n\t\t\tresultado = checkbox[posicion].value;\r\n\t}\r\n\t\r\n\treturn resultado;\r\n}\r\n\r\n\r\n// Funcion que devuelve el valor del check marcado\r\nfunction devuelveValorCheckMarcadoInt(checkbox)\r\n{\r\n\tvar posicion = devuelveCheckMarcado(checkbox);\r\n\tvar resultado = 0;\r\n\t\r\n\tif (posicion != -100)\r\n\t{  if (posicion == -1)\r\n\t\t\tresultado = checkbox.value;\r\n\t\telse\r\n\t\t\tresultado = checkbox[posicion].value;\r\n\t}\r\n\treturn parseInt(resultado);\r\n}\r\n\r\n// Funcion que devuelve los valores de los checkbox marcados\r\nfunction devuelveChecksMarcados(checkbox)\r\n{\r\n\tvar f = document.forms[0];\r\n\t\t\t\r\n\tvar aChecks = new Array();\r\n\t\r\n\tif(checkbox[0])\r\n\t{\r\n\t\tfor(var i=0;i<checkbox.length;i++)\r\n\t\t{\r\n\t\t\tif(checkbox[i].checked == true)\r\n\t\t\t{\r\n\t\t\t\taChecks[aChecks.length] = checkbox[i].value;\r\n\t\t\t}\r\n\t\t}\t\t\r\n\t}\t\r\n\telse\r\n\t{\t\r\n\t\tif(checkbox.checked)\r\n\t\t{\t\t\r\n\t\t\taChecks[aChecks.length] = checkbox.value;\r\n\t\t}\r\n\t}\r\n\t\t\r\n\treturn aChecks;\r\n}\r\n\r\n// Funcion que devuelve todos los valores de un checkbox\r\nfunction devuelveChecks(checkbox)\r\n{\r\n\tvar f = document.forms[0];\r\n\t\t\t\r\n\tvar aChecks = new Array();\r\n\r\n\tif(checkbox[0])\r\n\t{\r\n\t\tfor(var i=0;i<checkbox.length;i++)\r\n\t\t{\r\n\t\t\t\r\n\t\t\taChecks[aChecks.length] = checkbox[i].value;\r\n\r\n\t\t}\t\t\r\n\t}\t\r\n\telse\r\n\t{\t\t\r\n\t\t\taChecks[aChecks.length] = checkbox.value;\r\n\t}\r\n\t\t\r\n\treturn aChecks;\r\n}\r\n\r\n\r\nfunction cambiaTodosChecks(checkTodos, checkbox)\r\n{\r\n\tvar f = document.forms[0];\r\n\t\r\n\tvar bValor = checkTodos.checked;\r\n\t// Comprobamos si existe un unico check => No existe array\r\n\tif(checkbox[0])\r\n\t{\r\n\r\n\t\tfor (var i = 0; i < checkbox.length; i++) {\r\n\t\t\tcheckbox[i].checked = bValor;\r\n\t\t}\r\n\t}\r\n\telse\r\n\t{\r\n\t\tcheckbox.checked = bValor;\r\n\t}\r\n}\r\n\r\n\r\nfunction cargarChecks(checkbox)\r\n{\r\n   var i;\r\n     \tfor (i = 0; i < checkbox.length; i++) \r\n\t\t{\r\n\t\t\tcheckbox[i].checked = true; \r\n        }\r\n}\r\n\r\n\t\r\n"
          },
