            "text": "accion=anular&codigoUsuario=29485&antiguoCodigoCargo=15&rol=9&antiguoCodigoPartidoJudicial=14056&antiguoCodigoOrganismo=10478&codigoPartidoJudicialPadre=&codigoOrganismoPadre=&perteneceAPartidos=true&perteneceAOrganismos=true&codigosUsuarios=&antiguaFechaBaja=&puestoPrincipal=-&organismoHijo=&listadoOrganismoHijo=&error=false&tipo=D&usuario=15402487&c_usuario=IMALVAREZ&nombre=ISABEL+M%AA&apellido1=%C1LVAREZ&apellido2=GRANADOS&codigoDocumento=D&dni=15402487P&ocultoDni=15402487P&otro=&ocultoOtro=&sexo=M&anagrama=&partidoJudicial=Puente+Genil&codigoPartidoJudicial=14056&municipios=Puente+Genil&codigoMunicipio=14056&tipoOrganismo=Servicios+Comunes&codigoTipoOrganismo=24&organismo=Servicio+Com%FAn+de+Tramitaci%F3n+del+Tribunal+de+Instancia+de+Puente+Genil&codigoOrganismo=10478&cargo=Auxilio+Judicial&codigoCargo=15&cuerpo=Auxilio+judicial&codigoCuerpo=1&categoria=Interino&valorCategoria=I&caracter=&valorCaracter=&email=isabelm.alvarez.granados%40juntadeandalucia.es&emailExterno=&telefono=&fax=&fechaAlta=15%2F07%2F2026&cambiarIdPassword=3&observaciones=IN0000002553561&remLen2=256&ubicacion=Servicio+Com%FAn+de+Tramitaci%F3n+del+Tribunal+de+Instancia+de+Puente+Genil&codigoUbicacion=10478&ipVpn1v4=&ipVpn2v4=&ipVpn1v6=&ipVpn2v6=",
