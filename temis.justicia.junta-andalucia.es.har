            "text": "#menu {\r\n\twidth:  150px;\r\n}\r\n\r\nDIV.ComienzoMenu {\r\n\tbackground-color: #DEDF84;\r\n\tfont-size: 6px;\r\n}\r\n\r\nDIV.Categoria {\r\n\tbackground-color: #00824A;\r\n\tfont-weight: bold;\r\n\tcolor: #FFF;\r\n\tborder-right: 1px solid #00824A;\r\n\tfont-size: 12px;\r\n\ttext-align: center;\r\n\tpadding: 1px;\r\n\ttext-transform: uppercase;\r\n}\r\n\r\nDIV.Accion {\r\n\tborder-right: 1px solid #00824A;\r\n\tbackground-color: #F1F1C9;\r\n\tfont-size: 11px;\r\n\tpadding: 3px;\r\n\t\r\n}\r\n\r\nDIV.SubAccion {\r\n\tbackground-color: #F1F1C9;\r\n\tfont-size: 11px;\r\n\tpadding-left: 22px;\r\n\tcolor: #666;\r\n}\r\n\r\nDIV.FinMenu {\r\n\tbackground-color: #F1F1C9;\r\n\tborder-right: 1px solid #00824A;\t\r\n\tborder-bottom: 1px solid #00824A;\r\n\theight: 7px;\r\n\tfont: 0px;\r\n}\r\n\r\nSPAN.Flechita {\r\n\tfont-family: verdana, Geneva, Arial, Helvetica, sans-serif;\r\n\tcolor: #666;\r\n}\r\n\r\na {\r\n\tcolor: #666;\r\n\ttext-decoration: none;\r\n}\r\n\r\na:hover {\r\n\tcolor: #DC143C;\r\n\ttext-decoration: underline;\r\n}\r\n\r\n"
          },
