n.calendario\r\n{\r\n    FONT-WEIGHT: 600;\r\n    FONT-SIZE: 7.5pt;\r\n    COLOR: #555555;\r\n    FONT-FAMILY: Arial;\r\n    BACKGROUND-COLOR: #f8f8e0\r\n}\r\n.calendarionota\r\n{\r\n    FONT-WEIGHT: 100;\r\n    FONT-SIZE: 7pt;\r\n    COLOR: #555555;\r\n    FONT-FAMILY: Arial;\r\n    BACKGROUND-COLOR: #f8f8e0\r\n}\r\n.mes\r\n{\r\n    FONT-WEIGHT: 600;\r\n    FONT-SIZE: 7.5pt;\r\n    COLOR: #555555;\r\n    FONT-FAMILY: Arial;\r\n    BACKGROUND-COLOR: #ffffff\r\n}\r\n.nombremes\r\n{\r\n    FONT-WEIGHT: 600;\r\n    FONT-SIZE: 8pt;\r\n    COLOR: #009900;\r\n    FONT-FAMILY: Arial\r\n}\r\n.hora\r\n{\r\n    FONT-WEIGHT: 600;\r\n    FONT-SIZE: 8pt;\r\n    COLOR: #555555;\r\n    FONT-FAMILY: Arial;\r\n    BACKGROUND-COLOR: #dedf84\r\n}\r\n.descripcion\r\n{\r\n    FONT-WEIGHT: 600;\r\n    FONT-SIZE: 8pt;\r\n    COLOR: #555555;\r\n    FONT-FAMILY: Arial;\r\n    BACKGROUND-COLOR: #ededb8\r\n}\r\n.filapar\r\n{\r\n    FONT-WEIGHT: 600;\r\n    FONT-SIZE: 7.5pt;\r\n    COLOR: #000000;\r\n    FONT-FAMILY: Arial;\r\n    BACKGROUND-COLOR: #fefbee;\r\n\tfont-weight: normal;\r\n}\r\n.filaimpar\r\n{\r\n    FONT-WEIGHT: 600;\r\n    FONT-SIZE: 7.5pt;\r\n    COLOR: #000000;\r\n    FONT-FAMILY: Arial;\r\n    BACKGROUND-COLOR: #ebe9d2;\r\n\tfont-weight: normal;\r\n\tborder: 0px;\t\r\n}\r\n.filaimpar2\r\n{\r\n    FONT-WEIGHT: 600;\r\n    FONT-SIZE: 7.5pt;\r\n    COLOR: #000000;\r\n    FONT-FAMILY: Arial;\r\n    BACKGROUND-COLOR: #ebe9d2;\r\n\tfont-weight: normal;\r\n\tborder: 0px;\r\n\tcursor:default;\r\n}\r\n.filaimpar3\r\n{\r\n    FONT-WEIGHT: 600;\r\n    FONT-SIZE: 7.5pt;\r\n    COLOR: #000000;\r\n    FONT-FAMILY: Arial;\r\n    BACKGROUND-COLOR: #ebe9d2;\r\n\tfont-weight: normal;\r\n\tborder: 0px;\r\n\tcursor:pointer;\r\n\tTEXT-ALIGN: right;\r\n}\r\n.arbol\r\n{\r\n    FONT-WEIGHT: 600;\r\n    FONT-SIZE: 8pt;\r\n    COLOR: #003300;\r\n    FONT-FAMILY: Arial;\r\n    FONT-WEIGHT: normal;\r\n    border: 0px;\r\n}\r\n\r\n.arbolBold\r\n{\r\n    FONT-WEIGHT: 600;\r\n    FONT-SIZE: 8pt;\r\n    COL