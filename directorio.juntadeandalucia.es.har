            "mimeType": "text/css",
            "text": "@import url(/css/tabla.css);\r\n\r\n@font-face {\r\n        font-family: 'Noto Sans';\r\n        src:  url(\"/fonts/texgyreheroscn-regular-webfont.woff\")  format('woff'),\r\n                url(\"/fonts/texgyreheroscn-regular-webfont.ttf\")   format('truetype'),\r\n                url(\"/fonts/texgyreheroscn-regular-webfont.eot\")   format('eot'),\r\n                url(\"/fonts/texgyreheroscn-regular-webfont.svg\")   format('svg');\r\n        font-weight: normal;\r\n        font-style: normal;\r\n}\r\n\r\n@font-face {\r\n        font-family: 'Noto Sans';\r\n        font-weight: 400;\r\n        font-style: normal;\r\n        src: url('/fonts/Noto-Sans-regular/Noto-Sans-regular.eot');\r\n        src: url('/fonts/Noto-Sans-regular/Noto-Sans-regular.eot?#iefix') format('embedded-opentype'),\r\n                         local('Noto Sans'),\r\n                         local('Noto-Sans-regular'),\r\n                         url('/fonts/Noto-Sans-regular/Noto-Sans-regular.woff2') format('woff2'),\r\n                         url('/fonts/Noto-Sans-regular/Noto-Sans-regular.woff') format('woff'),\r\n                         url('/fonts/Noto-Sans-regular/Noto-Sans-regular.ttf') format('truetype'),\r\n                         url('/fonts/Noto-Sans-regular/Noto-Sans-regular.svg#NotoSans') format('svg');\r\n}\r\n\r\n@font-face {\r\n        font-family: 'Noto Sans';\r\n        font-weight: 700;\r\n        font-style: normal;\r\n        src: url('/fonts/Noto-Sans-700/Noto-Sans-700.eot');\r\n        src: url('/fonts/Noto-Sans-700/Noto-Sans-700.eot?#iefix') format('embedded-opentype'),\r\n                         local('Noto Sans Bold'),\r\n                         local('Noto-Sans-700'),\r\n                         url('/fonts/Noto-Sans-700/Noto-Sans-700.woff2') format('woff2'),\r\n                         url('/fonts/Noto-Sans-700/Noto-Sans-700.woff') format('woff'),\r\n                         url('/fonts/Noto-Sans-700/Noto-Sans-700.ttf') format('truetype'),\r\n                         url('/fonts/Noto-Sans-700/Noto-Sans-700.svg#NotoSans') format('svg');\r\n}\r\n\r\n@font-face {\r\n        font-family: 'Noto Sans';\r\n        font-weight: 400;\r\n        font-style: italic;\r\n        src: url('/fonts/Noto-Sans-italic/Noto-Sans-italic.eot');\r\n        src: url('/fonts/Noto-Sans-italic/Noto-Sans-italic.eot?#iefix') format('embedded-opentype'),\r\n                         local('Noto Sans Italic'),\r\n                         local('Noto-Sans-italic'),\r\n                         url('/fonts/Noto-Sans-italic/Noto-Sans-italic.woff2') format('woff2'),\r\n                         url('/fonts/Noto-Sans-italic/Noto-Sans-italic.woff') format('woff'),\r\n                         url('/fonts/Noto-Sans-italic/Noto-Sans-italic.ttf') format('truetype'),\r\n                         url('/fonts/Noto-Sans-italic/Noto-Sans-italic.svg#NotoSans') format('svg');\r\n}\r\n\r\n@font-face {\r\n        font-family: 'Noto Sans';\r\n        font-weight: 700;\r\n        font-style: italic;\r\n        src: url('/fonts/Noto-Sans-700italic/Noto-Sans-700italic.eot');\r\n        src: url('/fonts/Noto-Sans-700italic/Noto-Sans-700italic.eot?#iefix') format('embedded-opentype'),\r\n                         local('Noto Sans Bold Italic'),\r\n                         local('Noto-Sans-700italic'),\r\n                         url('/fonts/Noto-Sans-700italic/Noto-Sans-700italic.woff2') format('woff2'),\r\n                         url('/fonts/Noto-Sans-700italic/Noto-Sans-700italic.woff') format('woff'),\r\n                         url('/fonts/Noto-Sans-700italic/Noto-Sans-700italic.ttf') format('truetype'),\r\n                         url('/fonts/Noto-Sans-700italic/Noto-Sans-700italic.svg#NotoSans') format('svg');\r\n}\r\n\r\n@font-face {\r\n  font-family: 'Material Symbols Outlined';\r\n  font-style: normal;\r\n  src:  url('/fonts/material-icons/material-icons-outlined.eot');\r\n  src:  url('/fonts/material-icons/material-icons-outlined.eot?#iefix') format('embedded-opentype'),\r\n                url('/fonts/material-icons/material-icons-outlined.woff2') format('woff2'),\r\n                url('/fonts/material-icons/material-icons-outlined.woff') format('woff'),\r\n                url('/fonts/material-icons/material-icons-outlined.otf') format('opentype'),\r\n                ;\r\n}\r\n\r\n.material-symbols-outlined {\r\n        font-family: 'Material Symbols Outlined';\r\n        font-weight: normal;\r\n        font-style: normal;\r\n        font-size: 24px;  /* Preferred icon size */\r\n        display: inline-block;\r\n        line-height: 1;\r\n        text-transform: none;\r\n        letter-spacing: normal;\r\n        word-wrap: normal;\r\n        white-space: nowrap;\r\n        direction: ltr;\r\n}\r\n\r\n.material-symbols-outlined: hover {\r\n        cursor: pointer;\r\n}\r\n\r\n.icon_menu {\r\n        margin-right: 8px;\r\n        font-size: 30px;\r\n}\r\n\r\n.icon_listados {\r\n        color: #000000;\r\n}\r\n\r\nhtml, body {\r\n        margin: 0 auto 0 auto;\r\n        padding: 0;\r\n        background: #FFFFFF;\r\n\r\n        font-family: 'Noto Sans',Arial,Helvetica,sans-serif;\r\n        font-size: 14px;\r\n        color: #000000;\r\n}\r\n\r\nh1, h2, h3 {\r\n        font-family: 'Noto Sans';\r\n}\r\n\r\nh1 {\r\n        margin-top: 0;\r\n        font-size: 2.2em;\r\n        line-height: 1.3em;\r\n}\r\n\r\nh2 {\r\n        font-size: 1.7em;\r\n}\r\n\r\nh3 {\r\n        margin: 0;\r\n        font-size: 1.5em;\r\n}\r\n\r\nh2#subtitulo {\r\n        text-transform: uppercase;\r\n}\r\n\r\nimg {\r\n        border: 0;\r\n        -ms-interpolation-mode: bicubic;\r\n}\r\n\r\n.button {\r\n        align-items: center;\r\n        background: #9e5f00;\r\n        color: #fff;\r\n        border-radius: 20px;\r\n        border: 1px solid #9e5f00;\r\n        box-sizing: border-box;\r\n        cursor: pointer;\r\n        display: flex;\r\n        font: 500 1.4rem 'Source Sans Pro', sans-serif;\r\n        justify-content: center;\r\n        min-height: 40px;\r\n        padding: .8rem 2.4rem;\r\n        text-align: center;\r\n        text-decoration: none;\r\n        width: auto;\r\n        letter-spacing: .1px;\r\n        margin: 0px 5px;\r\n}\r\n\r\n.button:hover {\r\n        background: #f5f2da;\r\n        color: #9e5f00;\r\n        text-decoration: none;\r\n}\r\n\r\n/* Formularios */\r\n\r\n\r\ninput[type=\"text\"],\r\ninput[type=\"password\"],\r\ninput[type=\"search\"],\r\ninput[type=\"file\"],\r\nselect,\r\ntextarea {\r\n        background: #fff;\r\n        border: 1px solid #727272;\r\n        border-radius: 20px;\r\n        color: #302e2b;\r\n        font-size: 14px;\r\n        font-family: 'Noto Sans', Arial, Helvetica, sans-serif;\r\n        height: 40px;\r\n        margin: 0 0 0 0;\r\n        padding: 4px 16px;\r\n        box-sizing: border-box;\r\n        vertical-align: middle;        \r\n}\r\n\r\ninput[type=\"text\"],\r\ninput[type=\"password\"],\r\ninput[type=\"search\"],\r\ninput[type=\"file\"],\r\nselect {\r\n        height:30px;\r\n}\r\n\r\ntextarea {\r\n        width:100%;\r\n        font-size: 90%;\r\n        height:100%;\r\n}\r\n\r\n\r\n/*\r\n * Paginacion\r\n */\r\n\r\n#input.button {\r\n        height: 20px;\r\n        color: #333333;\r\n        font-size: 12px;\r\n        padding-left: 8px;\r\n        padding-right: 8px;\r\n        background: url(/img/interfaz/bg.gif) repeat-x #f0f0f0;\r\n        border: 1px solid #a4a4a4;\r\n}\r\n\r\n/* NEW LAYOUT */\r\n\r\nhtml {\r\n        height: 100%;\r\n}\r\n\r\nbody {\r\n        display: flex;\r\n        flex-direction: column;\r\n        height: 100%;\r\n}\r\n\r\nheader {\r\n\r\n}\r\n\r\nfooter {\r\n        height: 50px;\r\n        display: flex;\r\n        box-shadow: 0 3px 12px 0 rgba(128, 128, 128, .44);\r\n}\r\n\r\nfooter ul {\r\n        display: flex;\r\n        list-style: none;\r\n        flex-direction: row;\r\n        flex-wrap: nowrap;\r\n        align-content: center;\r\n        justify-content: center;\r\n        align-items: center;\r\n        width: 100%;\r\n        margin: 0;\r\n        padding: 0;\r\n}\r\n\r\nfooter li {\r\n        padding: 0 12px 0 8px;\r\n}\r\n\r\nfooter li:not(:last-child) {\r\n        border-right: 1px solid #373737;\r\n}\r\n\r\n.card {\r\n        border-radius: 10px;\r\n        background-color: #fff;\r\n        box-shadow: 0 2px 12px -5px #087342;\r\n}\r\n\r\n.card_header {\r\n        display: flex;\r\n        justify-content: space-between;\r\n        padding: 0 24px;\r\n        align-items: center;\r\n        min-height: 68px;\r\n        height: auto;\r\n        border-bottom: 1px solid #efefef;\r\n        background-color: #e9e9e9;\r\n        border-bottom: 1px solid #e7e7e7;\r\n        border-radius: 8px 8px 0 0;\r\n}\r\n\r\n.card_header_title {\r\n        display: flex;\r\n}\r\n\r\n\r\n.card_header h1, main h1 {\r\n        font-size: 2rem;\r\n        font-weight: 500;\r\n        margin-bottom: 0;\r\n}\r\n\r\n#header_topbar {\r\n        height: 58px;\r\n        background: #087342;\r\n\r\n        margin: 0;\r\n        padding: 0;\r\n        border: 0;\r\n        font-family: 'Noto Sans', sans-serif;\r\n        vertical-align: baseline;\r\n        line-height: 1.5;\r\n        box-sizing: border-box;\r\n}\r\n\r\n#header_menubar {\r\n        height: 56px;\r\n        background-color: #fefce8;\r\n        margin: 0;\r\n        padding: 0;\r\n        border: 0;\r\n        font-family: 'Noto Sans', sans-serif;\r\n        font-size: 14px;\r\n        vertical-align: baseline;\r\n        line-height: 1.5;\r\n        box-sizing: border-box;\r\n        box-shadow: 0 3px 12px 0 rgba(128, 128, 128, .44);\r\n}\r\n\r\n.inside {\r\n        display: flex;\r\n        justify-content: space-between;\r\n        margin: 0 auto;\r\n        width: 100%;\r\n        padding: 0 16px;\r\n        border: 0;\r\n        font-family: 'Noto Sans', sans-serif;\r\n        vertical-align: baseline;\r\n        box-sizing: border-box;\r\n}\r\n\r\n.logo {\r\n        display: flex;\r\n        height: 58px;\r\n        align-items: center;\r\n}\r\n\r\n.admdir_logo {\r\n        display: flex;\r\n        height: 58px;\r\n        align-items: center;\r\n}\r\n\r\n.admdir_logo img {\r\n        max-width: 180px;\r\n}\r\n\r\n.main_menu, .top_menu {\r\n        display: flex;\r\n        justify-content: center;\r\n}\r\n\r\n.main_menu .main_menu_options,\r\n.top_menu .top_menu_options {\r\n        justify-content: center;\r\n        align-items: center;\r\n        display: flex;\r\n        padding: 0;\r\n        margin: 0;\r\n        list-style: none;\r\n}\r\n\r\n.main_menu .main_menu_options li {\r\n   display: list-item;\r\n   text-align: -webkit-match-parent;\r\n   unicode-bidi: isolate;\r\n}\r\n\r\n.top_menu .top_menu_options li {\r\n   display: list-item;\r\n   text-align: -webkit-match-parent;\r\n   unicode-bidi: isolate;       \r\n}\r\n\r\n.top_menu .top_menu_options li {\r\n        height: 100%;\r\n        display: flex;\r\n        align-items: center;\r\n        color: #fff;\r\n        font-size: 1rem;\r\n}\r\n\r\n.top_menu .top_menu_options li:not(:last-child) {\r\n        border-right: 1px solid #ffffff80;\r\n}\r\n\r\n.top_menu .top_menu_options a {\r\n        color: #ffffff;\r\n        display: flex;\r\n        font-weight: 700;\r\n        justify-content: center;\r\n        align-items: center;\r\n        padding: 0 16px;\r\n}\r\n\r\na, a:visited {\r\n        font-family: 'Noto Sans', sans-serif;\r\n        color: #9e5f00;\r\n}\r\n\r\na {\r\n        text-decoration: none;\r\n}\r\n\r\n.main_menu .main_menu_options a {\r\n        display: flex;\r\n        font-weight: 700;\r\n        justify-content: center;\r\n        margin: 0 10px;\r\n        padding: 12px;\r\n        align-items: center;\r\n}\r\n\r\n.main_menu .main_menu_options a:hover {\r\n        border-bottom: 4px solid #3b3b3b;\r\n        text-decoration: none;\r\n        color: #3b3b3b;\r\n}\r\n\r\n.avatar {\r\n        height: 32px;\r\n        width: 32px;\r\n        border-radius: 50%;\r\n}\r\n\r\n#appbar_dropdown {\r\n        display: none;\r\n        position: absolute;\r\n        top:50px;\r\n\r\n        background: #fff;\r\n        margin-left: -108px;\r\n        width: 272px;\r\n        padding: 16px 0;\r\n        border-radius: 10px;\r\n        box-shadow: 0 2px 22px 0 rgba(214, 210, 204, .7);\r\n        z-index: 3000;\r\n}\r\n\r\n#appbar_dropdown li {\r\n        height: 64px;\r\n        padding: 0;\r\n        display: inline-block;\r\n        box-sizing: border-box;\r\n        width: 100%;\r\n        color: 0;\r\n}\r\n\r\n#appbar_dropdown li:not(:last-child) {\r\n        border-bottom: 1px solid #ebebeb;\r\n}\r\n\r\n#appbar_button:hover #appbar_dropdown {\r\n        display: block;\r\n}\r\n\r\n#appbar_dropdown li:hover {\r\n        background: #ebebeb;\r\n}\r\n\r\n#appbar_dropdown li a {\r\n}\r\n\r\n#close_dropdown {\r\n        display: none;\r\n        position: absolute;\r\n        top: 50px;\r\n        background: #fff;\r\n        margin-left: 0px;\r\n        width: 180px;\r\n        padding: 16px 0;\r\n        border-radius: 10px;\r\n        box-shadow: 0 2px 22px 0 rgba(214, 210, 204, .7);\r\n        z-index: 3000;  \r\n}\r\n\r\n#close_dropdown li:hover {\r\n        background: #ff000026;\r\n}\r\n\r\n#close_dropdown li a {\r\n        color: #f13158;\r\n}\r\n\r\n#close_button:hover #close_dropdown {\r\n        display: block;\r\n}\r\n\r\n#submenu_sirhus,\r\n#submenu_recursos {\r\n        display: none;\r\n        position: absolute;\r\n        margin-top: -10px;\r\n\r\n        background-color: #fefce8;\r\n        padding: 16px 0;\r\n        border-radius: 10px;\r\n        box-shadow: 0 2px 22px 0 rgba(214, 210, 204, .7);\r\n        z-index: 3000;\r\n}\r\n\r\n#submenu_sirhus {\r\n        width: 200px;\r\n        margin-left: -20px;\r\n}\r\n\r\n#submenu_recursos {\r\n        width: 200px;\r\n        margin-left: -20px;\r\n}\r\n\r\n#submenu_sirhus li,\r\n#submenu_recursos li {\r\n        list-style: none;\r\n}\r\n\r\n#submenu_sirhus li:hover,\r\n#submenu_recursos li:hover {\r\n        border-bottom: 0;\r\n        background-color: #9e5f00;\r\n}\r\n\r\n#submenu_sirhus li:hover a,\r\n#submenu_recursos li:hover a {\r\n        color: #fefce8 !important;\r\n}\r\n\r\n#submenu_sirhus a:hover,\r\n#submenu_recursos a:hover {\r\n        color: #fefce8;\r\n}\r\n\r\n#submenu_sirhus li a,\r\n#submenu_recursos li a {\r\n        display: flex;\r\n        font-weight: 700;\r\n        justify-content: center;\r\n        margin: 0 20px;\r\n        padding: 12px;\r\n        align-items: center;\r\n        text-align: center;\r\n}\r\n\r\n#submenu_sirhus_button:hover #submenu_sirhus,\r\n#submenu_recursos_button:hover #submenu_recursos {\r\n        display: block;\r\n}\r\n\r\n#submenu_sirhus_button:hover #submenu_sirhus ul li a,\r\n#submenu_recursos_button:hover #submenu_recursos ul li a {\r\n        color: #9e5f00 !important;\r\n}\r\n\r\n#submenu_sirhus_button:hover #submenu_sirhus ul li a:hover,\r\n#submenu_recursos_button:hover #submenu_recursos ul li a:hover {\r\n        color: #fefce8 !important;\r\n}\r\n\r\n.subsubmenu {\r\n        display:none;\r\n        position:absolute;\r\n        margin-left: -230px;\r\n        width: 250px;\r\n\r\n        background-color: #fefce8;\r\n        padding: 16px 0;\r\n        border-radius: 10px;\r\n        box-shadow: 0 2px 22px 0 rgba(214, 210, 204, .7);\r\n        z-index: 3100;\r\n}\r\n\r\n#submenu_sirhus_button #submenu_recursos .withsubmenu:hover .subsubmenu {\r\n        display: block;\r\n}\r\n\r\n\r\n@media only screen and (max-width: 1024px) {\r\n        .main_menu .main_menu_options a {\r\n                margin: 0;\r\n        }\r\n\r\n        .form_field_value input,\r\n        .form_field_value select,\r\n        .form_field_value textarea {\r\n            width: 100%;\r\n        }\r\n\r\n        .hid_tablet {\r\n                display: none;\r\n        }\r\n}\r\n\r\n@media only screen and (max-width: 450px) {\r\n\r\n        .form_field {\r\n                flex-direction: column;\r\n        }\r\n\r\n        .form_field_value {\r\n                align-items: center;\r\n        }\r\n\r\n        .explain {\r\n                width:100%;\r\n        }\r\n\r\n        #extra {\r\n                display: none;\r\n                background:yellow;\r\n        }\r\n\r\n        .hid_mobile {\r\n                display: none;\r\n        }\r\n\r\n        .inside {\r\n                padding: 0;\r\n        }\r\n\r\n        .dis_margin_mobile {\r\n                margin: 0;\r\n        }\r\n\r\n        .logo {\r\n                margin-left: 16px;\r\n        }\r\n\r\n        .main_menu .main_menu_options a {\r\n                margin: 0;\r\n                padding: 12px 0;\r\n        }\r\n\r\n        .card_header {\r\n                flex-direction: column;\r\n        }\r\n\r\n\r\n        .form_field_value {\r\n                justify-content: center;\r\n        }\r\n\r\n        .card_header {\r\n                min-height: 50px;\r\n        }\r\n        \r\n}\r\n\r\n@media only screen and (max-width: 400px) {\r\n        footer {\r\n                display: none;\r\n        }\r\n\r\n        .top_menu .top_menu_options a {\r\n                padding: 8px;\r\n        }\r\n\r\n        .form_field_value input,\r\n        .form_field_value select,\r\n        .form_field_value textarea {\r\n            width: 100%;\r\n        }\r\n\r\n        #user_name_in_menu {\r\n                display: none;\r\n        }\r\n\r\n        .mensaje_info, .mensaje_error {\r\n                display: none;\r\n        }\r\n}\r\n"
