            "mimeType": "text/css",
            "text": "/* \n\tGrey Suits you Sir. Please host the images on your own server.\n\twritten by Stuart Colville http://www.muffinresearch.co.uk\n*/\n\ntable,td {\n\tborder-collapse: collapse;\n\tborder-right: 1px solid #eee;\n}\n\ntd:last-of-type {\n\tborder-right: none !important;\n}\n\ntable {\n\tborder:1px solid #EEE\n}\n\nthead {\n    line-height: 1.5;\n    box-sizing: border-box;\n\tmin-height: 50px;\n\theight: 50px;\n\tfont-weight: bold;\n}\n\nthead tr\n{\n\tbackground-color: #f1f1f1;\n\tcolor: #302e2b;\n\tborder-bottom: 1px solid #e7e7e7;\n\ttext-align: left;\t\n}\n\nthead th.centered {\n\ttext-align: center;\n}\n\nthead th a, thead th a:visited\n{\n\tcolor: #302e2b;\n\ttext-decoration: none;\n}\n\nthead th a:hover\n{\n\n}\n\ntbody th\n{\n\tcolor\t\t          : #f1f1f1;\n\tborder-bottom: 1px solid #e7e7e7;\n}\n\ntbody th\n{\n  text-align            : left;\n  font-weight           : normal;\n}\n\ntbody tr td\n{\n  padding               : 8px\n}\n\ntbody td.centered {\n\ttext-align: center;\n}\n\ntbody tr:hover,\ntbody tr:hover td,\ntbody tr:hover td > *\n{\n\tbackground-color: #f6fbff;\n  _cursor: hand;\n  cursor: pointer;\n}\n\ntfoot td,\ntfoot th\n{\n  border-left           : none;\n  border-top            : 1px solid #CCC;\n  padding               : 4px;\n  background            : #FFF url(../img/tabla/img/tabla/foot_bck.gif) repeat;\n  color                 : #666;\n}\n\ncaption\n{\n  text-align            : left;\n  font-size             : 120%;\n  padding               : 10px 0;\n  color                 : #666;\n}\n\ntable tbody a\n{\n\tcolor: #9e5f00;\n\ttext-decoration:none;\n}\n\ntable tbody a:visited\n{\n}\n\ntable tbody a:hover\n{\n}\n\ntable tbody a:active\n{\n}\n\n.td_nombrefich {\n\t/*width: 40%;*/\n}\n\n.td_data_centered{\n\ttext-align: center !important;\n}\n\n.formtable {\n\tborder: 0;\n\ttable-layout: fixed;\n\twidth: 100%;\n}\n\n.formtable tbody {\n\tborder: 0;\n\ttable-layout: fixed;\n\twidth: 100%;\n}\n\n.formtable input[type=\"text\"] {\n\tmargin: 0;\t\n}\n\n.formtable td {\n\tvertical-align: top;\n}\n\n.formtable label {\n\tpadding: 0;\n}"
