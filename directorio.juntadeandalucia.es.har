          "content": {
            "size": 22161,
            "mimeType": "text/html",
            "compression": -30,
            "text": "<!DOCTYPE HTML PUBLIC \"-//W3C//DTD HTML 4.01 Transitional//EN\" \"http://www.w3.org/TR/html4/loose.dtd\">\n<html lang=\"es\" >\n<head>\n  <title>Usuarios</title>\n  <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\">\n  <meta http-equiv=\"Content-Script-Type\" content=\"text/javascript; charset=utf-8\">\n  <meta http-equiv=\"Content-Style-Type\" content=\"text/css\">\n  <link rel=\"stylesheet\" href=\"/css/admdir.css\" type=\"text/css\">\n  <link rel=\"stylesheet\" href=\"/css/pwdmeter.css\" type=\"text/css\">\n  <link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined\" rel=\"stylesheet\" />\n  <style  type=\"text/css\"></style>\n  <script language=\"javascript\" src=\"/scripts/usuarios.js\" type=\"text/javascript\"></script>\n  <script language=\"javascript\" src=\"/scripts/pwdmeter.js\" type=\"text/javascript\"></script>\n</head>\n<body onLoad=\"javascript:ocultaCortinilla();muevePosicion('0');\">\n<form id=\"formulario\"  method=\"post\" action=\"es.sadesi.admdirectorio.servlets.UsuariosMain\">\n<input type=\"hidden\" name=\"accion\" value=\"consulta\">\n<input type=\"hidden\" name=\"botonPulsado\" value=\"confirmarPassword\">\n<input type=\"hidden\" name=\"datoAuxiliar\" value=\"0\" >\n<input type=\"hidden\" name=\"tokenParametro\" value=\"d19ca164-f581-4dd5-a94b-a53be057cb16\">\n<header>\n  <div id=\"header_topbar\">\n    <div class=\"inside\">\n      <div class=\"logo\"><img src=\"/img/logo_ja.png\"></div>\n      <nav aria-label=\"navegacion principal\" class=\"top_menu\">\n        <ul class=\"top_menu_options\">\n          <li id=\"appbar_button\">\n            <a href=\"#\"><span class=\"material-symbols-outlined\">apps</span></a>\n            <ul id=\"appbar_dropdown\">\n              <li>\n                <a href=\"https://correo.juntadeandalucia.es/\" target=\"_blank\">\n                  <img src=\"/img/icon-appbar-4-webmail.png\" alt=\"Acceso a Webmail\">\n                </a>\n              </li>\n              <li>\n                <a href=\"https://consigna.juntadeandalucia.es/\" target=\"_blank\">\n                  <img src=\"/img/icon-appbar-4-consigna.png\" alt=\"Acceso a Consigna\">\n                </a>\n              </li>\n              <li>\n                <a href=\"https://redprofesional.juntadeandalucia.es/\" target=\"_blank\">\n                  <img src=\"/img/icon-appbar-4-red-profesional.png\" alt=\"Acceso a Red Profesional\">\n                </a>\n              </li>\n              <li>\n                <a href=\"https://ficheros.juntadeandalucia.es/\" target=\"_blank\">\n                  <img src=\"/img//icon-appbar-ficheros.png\" alt=\"Ficheros Junta\">\n                </a>\n              </li>\n              <li>\n                <a href=\"https://reservas.juntadeandalucia.es/\" target=\"_blank\">\n                  <img src=\"/img/icon-appbar-reservas_b.png\" alt=\"Reserva de Recursos\">\n                </a>\n              </li>\n              <li>\n                <a href=\"https://micuenta.juntadeandalucia.es/\" target=\"_blank\">\n                  <img src=\"/img/icon-appbar-4-micuenta.png\" alt=\"Mi Cuenta\">\n                </a>\n              </li>\n            </ul>\n          </li>\n          <li id=\"close_button\">\n            <a href=\"#\">\n              <span id=\"user_name_in_menu\">&nbsp;just9.sandetel.ext - jus</span>\n              <span class=\"material-symbols-outlined\">keyboard_arrow_down</span>\n            </a>\n            <ul id=\"close_dropdown\">\n              <li>\n                <a href=\"/logout.jsp\">\n                  <span class=\"material-symbols-outlined\">cancel</span>&nbsp;Cerrar sesión</a>                \n              </li>\n            </ul>\n          </li>\n          <li>\n            <a href=\"https://ayuda-productividad.juntadeandalucia.es/aplicaciones/admdir/\" target=\"_blank\">\n              <span class=\"material-symbols-outlined icon_menu dis_margin_mobile\">help</span><span class=\"hid_mobile\">Ayuda</span></a>\n          </li>\n        </ul>\n      </nav>\n    </div>\n      \n  </div>\n  \n  <div id=\"header_menubar\">\n    <div class=\"inside\">\n      <div class=\"admdir_logo\">\n        <a href=\"https://directorio.juntadeandalucia.es/\"><img src=\"/img/admdir_logo.png\"></a>\n      </div>\n      <nav aria-label=\"navegacion\" class=\"main_menu\">\n        <ul class=\"main_menu_options\">\n          <li>\n              <a href=\"/myServlets/es.sadesi.admdirectorio.servlets.AdministradorMain\">\n                <span class=\"material-symbols-outlined icon_menu\">home</span>\n                <span class=\"hid_mobile hid_tablet\">Inicio</span></a>\n            </li>\n            <li>\n              <a href=\"/myServlets/es.sadesi.admdirectorio.servlets.UsuariosMain\">\n                <span class=\"material-symbols-outlined icon_menu\">group</span>\n                <span class=\"hid_mobile hid_tablet\">Usuarios</span></a>\n            </li>\n            <li>\n              <a href=\"/myServlets/es.sadesi.admdirectorio.servlets.ListasMain\">\n                <span class=\"material-symbols-outlined icon_menu\">library_books</span>\n                <span class=\"hid_mobile hid_tablet\">Listas</span></a>\n            </li>\n            <li id=\"submenu_sirhus_button\">\n                <a href=\"#\">\n                  <span class=\"material-symbols-outlined icon_menu\">accessibility</span>\n                  <span class=\"hid_mobile hid_tablet\">Sirhus</span></a>                \n                <ul id=\"submenu_sirhus\">\n                  <li><a href=\"/myServlets/es.sadesi.admdirectorio.servlets.SirhusAltas\">Altas</a></li>\n                  <li><a href=\"/myServlets/es.sadesi.admdirectorio.servlets.SirhusBajas\">Bajas</a></li>\n                  <li><a href=\"/myServlets/es.sadesi.admdirectorio.servlets.SirhusTraslados\">Traslados</a></li>\n                </ul>\n              </li>\n            <li id=\"submenu_recursos_button\">\n              <a href=\"#\">\n                <span class=\"material-symbols-outlined icon_menu\">apartment</span>\n                <span class=\"hid_mobile hid_tablet\">Recursos</span></a>\n                <ul id=\"submenu_recursos\">\n                  <li><a href=\"/myServlets/es.sadesi.admdirectorio.servlets.RecursosAdmDelegado\"   >Adm. Delegados</a></li>\n                  <li><a href=\"/myServlets/es.sadesi.admdirectorio.servlets.RecursosEdificios \"    >Edificios</a></li>\n                  <li><a href=\"/myServlets/es.sadesi.admdirectorio.servlets.RecursosNodos\"         >Nodos</a></li>\n                  <li><a href=\"/myServlets/es.sadesi.admdirectorio.servlets.RecursosPuestosTrabajo\">Puestos de Trabajo</a></li>\n                  <li><a href=\"/myServlets/es.sadesi.admdirectorio.servlets.RecursosProveedores\"   >Proveedores</a></li>\n                  <li><a href=\"/myServlets/es.sadesi.admdirectorio.servlets.RecursosServicios\"     >Servicios</a></li>\n                  <li><a href=\"/myServlets/es.sadesi.admdirectorio.servlets.RecursosZtna\"          >Ztna</a></li>\n                </ul>\n            </li>\n            <li>\n              <a href=\"/myServlets/es.sadesi.admdirectorio.servlets.FiltrosMain\">\n                <span class=\"material-symbols-outlined icon_menu\">filter_alt</span>\n                <span class=\"hid_mobile hid_tablet\">Filtros</span></a>\n            </li>\n            </ul>\n      </nav>\n    </div>\n  </div>\n</header>\n\n<div class=\"cabecera_cortinilla\" id=\"cabecera_cortinilla\">\n  Cargando página... Por favor, espere...\n</div>\n\n<main>\n  <nav aria-label=\"Migas de pan\" class=\"miga_contenedor\">\n    <a href=\"/myServlets/es.sadesi.admdirectorio.servlets.UsuariosMain\">Usuarios</a>&nbsp;>&nbsp;\n    <span>Buscador</span>\n  </nav>\n  <div class=\"inside\">\n    <div id=\"vista_datos\"> \n      <div id=\"datos_usuario\" class=\"card\">\n        <div class=\"card_header\">\n          <div class=\"card_header_title\">\n            <h1>Usuarios</h1>\n          </div>\n        </div>\n\n        <!-- *************************************** -->\n        <!-- *      S   U   B   M   E   N   U      * -->\n        <!-- *************************************** -->\n        <div id=\"submenu\" class=\"submenu\">\n          <ul>\n            <li class=\"activo submenu_usuarios\">\n                <a href=\"javascript:inicializaTiposUsuario('consulta','','');\">\n                  <span class=\"material-symbols-outlined icon_menu\">search</span>\n                  <span class=\"hid_mobile hid_tablet\">Buscador</span>\n                </a>\n              </li>\n              <li class=\"submenu_usuarios\">\n                <a href=\"javascript:enviar('nuevo','pantalla1','');\">\n                  <span class=\"material-symbols-outlined icon_menu\">person_add</span>\n                  <span class=\"hid_mobile hid_tablet\">Nuevo Usuario</span>\n                </a>\n              </li>\n              <li class=\"submenu_usuarios\">\n                <a href=\"javascript:enviar('altasMasivas','pantalla1','');\">\n                  <span class=\"material-symbols-outlined icon_menu\">groups</span>\n                  <span class=\"hid_mobile hid_tablet\">Operaciones Masivas</span>\n                </a>\n              </li>\n              <li class=\"submenu_usuarios\">\n                <a href=\"javascript:enviar('consultaEstado','pantalla1','')\">\n                  <span class=\"material-symbols-outlined icon_menu\">find_in_page</span>\n                  <span class=\"hid_mobile hid_tablet\">Consulta Estado Sirhus</span>\n                </a>\n              </li>\n              <li class=\"submenu_usuarios\">\n                <a href=\"javascript:inicializaTiposUsuario('listados','pantalla1','');\">\n                  <span class=\"material-symbols-outlined icon_menu\">list_alt</span>\n                  <span class=\"hid_mobile hid_tablet\">Listados de Usuarios</span>\n                </a>\n              </li>\n            </ul>\n        </div>\n\n        <!-- ******************************************* -->\n        <!-- *      B   U   S   C   A   D   O   R      * -->\n        <!-- ******************************************* -->\n        <div class=\"buscador\">\n          <!-- ************************************* -->\n          <!-- *   F I L T R O   B U S Q U E D A   * -->\n          <!-- ************************************* -->\n          <div class=\"buscador_contenido\">\n              Buscar por:&nbsp;&nbsp;\n              <select name=\"filtroAtributo\" onChange=\"javascript:validaFiltroBusqueda('cambioFiltro','cambioFiltro');\" title=\"Buscar por\">\n                <option value=\"identificador\" selected>Identificador</option>\n                <option value=\"dni\"           >DNI</option>\n                <option value=\"correo\"        >Correo electrónico</option>\n                <option value=\"nombre\"        >Nombre y/o Apellidos</option>\n                <option value=\"tipoUsuario\"   >Tipo de Usuario</option>\n                <option value=\"edificio\">Edificio</option>\n                <option value=\"servicio\">Servicio</option>\n                <option value=\"centroDirectivo\"> Centro Directivo</option>\n                  <option value=\"centroDestino\"> Centro Destino</option>\n                </select>\n              &nbsp;&nbsp;\n              <select name=\"filtroTipoBusqueda\" size=\"1\" title=\"Tipo de busqueda\">\n                <option value=\"empezando\"   selected  >empezando por</option>\n                <option value=\"igual\"             >igual a</option>\n                <option value=\"terminando\"   >terminando en</option>\n                <option value=\"conteniendo\" >conteniendo a</option>\n              </select>\n              &nbsp;&nbsp;\n              <input name=\"filtroValor\" type=\"text\" maxlength=\"50\" size=\"20\" value=\"alejandro.molina.avila\" title=\"Valor\">\n            </div>\n            <div class=\"buscador_contenido\"><span class=\"form_text\">Indique al menos cuatro caracteres para realizar la búsqueda.</span></div>\n            <div class=\"buscador_contenido\">\n              <!-- Tipos de usuarios -->\n              <input type=\"hidden\" name=\"marcarSirhus\"    value=\"SI\">\n              <input type=\"hidden\" name=\"marcarInternos\"  value=\"NO\">\n              <input type=\"hidden\" name=\"marcarExternos\"  value=\"NO\">\n              <input type=\"hidden\" name=\"marcarGenericos\" value=\"NO\">\n              <input type=\"hidden\" name=\"marcarNA\"        value=\"NO\">\n              Tipo de Usuario (*):&nbsp;&nbsp;\n              <input type=\"checkbox\" name=\"seleccionarSirhus\"   checked title=\"Sirhus\">Sirhus&nbsp;&nbsp;\n              <input type=\"checkbox\" name=\"seleccionarInternos\"  title=\"Internos\">Internos&nbsp;&nbsp;\n              <input type=\"checkbox\" name=\"seleccionarExternos\"   title=\"Externos\">Externos&nbsp;&nbsp;\n              <input type=\"checkbox\" name=\"seleccionarGenericos\"  title=\"Genericos\">Genéricos&nbsp;&nbsp;\n              <input type=\"checkbox\" name=\"seleccionarNA\"  title=\"Otros\">Otros&nbsp;\n            </div>\n            <div class=\"buscador_contenido\">\n              <input type=\"hidden\" name=\"numUsuariosAntiguo\" value=\"25\">\n              Número de usuarios por tipo (*):&nbsp;&nbsp;\n              <input type=\"text\" name=\"numUsuarios\" value=\"25\" size=\"4\" maxlength=\"4\" title=\"Numero de usuarios\">\n            </div>            \n            <div class=\"buscador_contenido\"><span class=\"form_text\">(*): Campos obligatorios</span></div>\n            <!-- Botones -->\n            <div class=\"botones\" id=\"botones_buscador\">\n              <a class=\"button\" name=\"MOSTRAR_RESULTADOS\" title=\"Mostrar Resultados\" id=\"MOSTRAR_RESULTADOS\" \n              href=\"javascript:validaFiltroBusqueda('SI','consulta')\">MOSTRAR RESULTADOS</a>\n              <a class=\"button\" name=\"PERMISOS_APLICACIONES\" title=\"Permisos Aplicaciones\" id=\"PERMISOS_APLICACIONES\" \n                href=\"javascript:validaFiltroBusqueda('SI','permisos');\">PERMISOS APLICACIONES</a>\n              </div>\n          </div>\n\n        <div class=\"resultados_busqueda\">\n          <!-- ************************************************************** -->\n    <!-- *                                                            * -->\n    <!-- *            S      I      R      H     U      S             * -->\n    <!-- *                                                            * -->\n    <!-- ************************************************************** -->\n    <h2>USUARIOS DE SIRHUS</h2>\n      <div class=\"listado\">\n          <div class=\"cabecera\">\n            <span class=\"capa_oculta\">&nbsp;</span>\n            <span class=\"campo ancho2\">Correo electrónico</span>\n            <span class=\"campo ancho2\">Nombre y Apellidos</span>\n            <span class=\"icono\">Contraseña</span>\n            <span class=\"icono\">Editar</span>\n            <span class=\"icono\">Borrar</span>\n          </div>\n          <a id=\"ancla_fila_0\" name=\"ancla_fila_0\" title=\"Ancla\"><span class=\"capa_oculta\">&nbsp;</span></a>\n            <div class=\"fila_seleccionada\" id=\"fila_0\">\n              <span class=\"campo ancho2\">alejandro.molina.avila@juntadeandalucia.es</span>\n              <span class=\"campo ancho2\">Alejandro Molina Avila</span>\n              <span class=\"icono\">\n                <a href=\"#ancla_fila_0\" id=\"icono_password_0\" \n                    name=\"icono_password_0\" onClick=\"javascript:mostrar_capa('password','0','1')\" \n                    title=\"Cambiar Contraseña\">\n                    <span class=\"material-symbols-outlined icon_listados\">key</span></a>\n                </span>\n              <span class=\"icono\">\n                <a href=\"#ancla_fila_0\" onClick=\"javascript:enviar('modificacion','pantalla1','uid=alejandro.molina.avila,o=jus,o=empleados,o=juntadeandalucia,c=es');\" id=\"icono_editar_0\" \n                  name=\"icono_editar_0\" title=\"Editar Usuario\">\n                  <span class=\"material-symbols-outlined icon_listados\">edit</span>\n                </a>\n              </span>\n              <span class=\"icono\">\n                <span class=\"capa_oculta\">&nbsp;</span>\n              </span>\n            </div>\n            <!-- ***************************************************** -->\n            <!-- *   S I R H U S   C A M B I A R   P A S S W O R D   * -->\n            <!-- ***************************************************** -->\n            <div class=\"fila_detalle_seleccionado\" id=\"capa_password_0\">\n              <input type=\"hidden\" name=\"usuarioWindows\" value=\"NO\">\n              <input type=\"hidden\" name=\"passCaducadoCP\" value=\"SI\">\n              <input type=\"hidden\" name=\"dn\" value=\"uid=alejandro.molina.avila,o=jus,o=empleados,o=juntadeandalucia,c=es\">\n              <div class=\"mensaje_ok\">La contrase&ntilde;a del usuario se actualiz&oacute; correctamente.</div>\n              <div class=\"form_field\">\n                <div class=\"form_field_label\"><label>Nombre:</label></div>\n                <div class=\"form_field_value\">Alejandro Molina Avila</div>\n              </div>\n              <div class=\"form_field\">\n                <div class=\"form_field_label\"><label>Identificador:</label></div>\n                <div class=\"form_field_value\">alejandro.molina.avila</div>\n              </div>\n              <div class=\"form_field\">\n                  <div class=\"form_field_label\"><label>Tipo de usuario:</label></div>\n                  <div class=\"form_field_value\">Con buzón de correo.</div>\n                </div>\n                <div class=\"form_field\">\n                  <div class=\"form_field_label\"><label>Correo electrónico:</label></div>\n                  <div class=\"form_field_value\">alejandro.molina.avila@juntadeandalucia.es</div>\n                </div>\n              <div class=\"form_field\">\n                  <div class=\"form_field_label\"><label>Último cambio de contraseña:</label></div>\n                  <div class=\"form_field_value\">15/07/2026</div>\n                </div>\n              <div class=\"form_field\">\n                  <div class=\"form_field_label\"><label>Contraseña:</label></div>\n                  <div class=\"form_field_value\">\n                    <input type='password' class=\"input_text\" title='Contraseña' name='pwd_modificacion' value='' size='15' onkeyup=\"chkPass(this.value,'0');\">\n                    &nbsp;\n                    <div id=\"scoreBarBorder_0\" class=\"scoreBarBorder\">\n                      <div id=\"score_0\" class=\"score\">0%</div>\n                      <div id=\"scorebar_0\" class=\"scorebar\">&nbsp;</div>\n                    </div>\n                    <span id=\"complexity_0\" class=\"complexity\">&nbsp;</span>\n                  </div>\n                </div>\n                <div class=\"form_field\">\n                  <div class=\"form_field_label\"><label>Confirme Contraseña:</label></div>\n                  <div class=\"form_field_value\">\n                    <input type='password' class=\"input_text\" title='Confirmacion de contraseña' name='pwd2_modificacion' value='' size='15'>\n                  </div>\n                </div>\n                <div class=\"form_field\">\n                  <div class=\"form_field_label\"><label>Obligar al usuario a actualizar la contraseña:</label></div>\n                  <div class=\"form_field_value\"><input type='checkbox' title='Forzar passCaducado' name='pc' value='' checked></div>\n                </div>\n                <div class=\"form_field\">\n                  <div class=\"form_field_label\"><label>Usuario Windows:</label></div>\n                  <div class=\"form_field_value\"><input type='checkbox' title='Usuario windows' name='uw' value='' ></div>\n                </div>\n                <h3>NORMAS PARA EL CAMBIO DE CONTRASEÑA:</h3>\n<ul>\n\t<li>Debe incluir un mínimo de 12 caracteres.</li>\n\t<li>Debe incluir al menos un dígito (0 - 9).</li>\n\t<li>Debe tener al menos un carácter de letras mayúsculas o minúsculas (Excepto la ñ y las letras acentuadas).</li>\n\t<li>No puede contener el <em>usuario</em>, ni el <em>nombre</em>, ni el <em>primer apellido</em>, ni los caracteres especiales '@' y '\"'.</li>\n\t<li>Debe incluir al menos uno de los siguientes símbolos: !#$%&'()*+,-./:;&lt;=&gt;?[\\]^_`{|}~</li>\n</ul> <div class=\"botones\" id=\"botones_sirhus_cambia_password\">\n                <a class=\"button\" name=\"ACTUALIZAR_0\" title=\"Actualizar\" id=\"ACTUALIZAR_0\" href=\"javascript:validaPantallaCambioPassword('0','1');\">ACTUALIZAR</a>\n              </div>\n\n            </div>\n            </div>\n      <!-- *************************************************************************** -->\n    <!-- *                                                                         * -->\n    <!-- *            I      N      T      E     R      N      O      S            * -->\n    <!-- *                                                                         * -->\n    <!-- *************************************************************************** -->\n    <!-- *************************************************************************** -->\n    <!-- *                                                                         * -->\n    <!-- *            E      X      T      E     R      N      O      S            * -->\n    <!-- *                                                                         * -->\n    <!-- *************************************************************************** -->\n    <!-- ********************************************************************************** -->\n    <!-- *                                                                                * -->\n    <!-- *            G      E      N      E     R      I      C      O      S            * -->\n    <!-- *                                                                                * -->\n    <!-- ********************************************************************************** -->\n    <!-- *************************************************************************** -->\n    <!-- *                                                                         * -->\n    <!-- *            S      I      N            T      I      P      O            * -->\n    <!-- *                                                                         * -->\n    <!-- *************************************************************************** -->\n    </div>\n      </div>\n    </div>\n  </div>\n</main>\n<footer>\r\n  <div class=\"inside\">\r\n    <ul>\r\n      <li><span class=\"server\">© Junta de Andalucía 2026</span></li>\r\n    </ul>\r\n  </div>\r\n</footer>\r\n</form>\n<script type=\"text/javascript\" src=\"/scripts/jquery.min.js\"></script>\n<script type=\"text/javascript\" src=\"/scripts/jquery-migrate.min.js\"></script>\n<script type=\"text/javascript\" src=\"/scripts/back-to-top.js\"></script>\n\n</body>\n</html>\n"
