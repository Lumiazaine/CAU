            "mimeType": "text/css",
            "text": "@import url(\"/css/cabecera.css\");\r\n\r\n/***************************************/\r\n/*      S   U   B   M   E   N   U      */\r\n/***************************************/\r\n.submenu {\r\n        height: auto;\r\n        padding: 0px;\r\n        display: flex;\r\n}\r\n\r\n.submenu ul {\r\n        margin: 0px;\r\n        padding: 0px;\r\n        align-items: center;\r\n        display: flex;\r\n        width:100%;\r\n}\r\n\r\n.submenu li {\r\n        margin: 0px;\r\n        padding-left: 24px;\r\n        list-style: none;\r\n        background-color: #f6f6f6;\r\n        min-height: 46px;\r\n        height: auto;\r\n        font-size: 1.1rem;\r\n        display: flex;\r\n        align-items: center;\r\n}\r\n.submenu li a {\r\n        color: #000000;\r\n        font-weight: 700;\r\n        display: flex;\r\n        align-items: center;\r\n}\r\n\r\n.submenu .activo {\r\n        background-color: #e9e9e9;\r\n}\r\n.submenu_listas {\r\n        width: 33%;\r\n}\r\n.submenu_administradores {\r\n        width:16%;\r\n}\r\n.submenu_sirhus {\r\n        width: 50%;\r\n}\r\n.submenu_usuarios {\r\n        width: 20%;\r\n}\r\n.submenu_usuarios_ad {\r\n        width: 50%;\r\n}\r\n\r\n\r\n/*******************************************/\r\n/*      M   E   N   S   A   J   E   S      */\r\n/*******************************************/\r\n.mensaje_info, .mensaje_error, .mensaje_ok {\r\n        border-radius: 10px;\r\n        box-shadow: 0 2px 12px -5px #087342;\r\n        display: flex;\r\n        flex-direction: column;\r\n        margin: 1em 0;\r\n        padding: 1em;\r\n        font-size: 1.5rem;\r\n}\r\n\r\n.mensaje_info {\r\n        background-color: #fefce8;\r\n        color: #000000;\r\n}\r\n\r\n.mensaje_error {\r\n        background-color: #fa6948;\r\n        color: #ffffff;\r\n        font-weight: bold;\r\n}\r\n\r\n.mensaje_ok {\r\n        background-color: #68c81b;\r\n        color: #f0f0f0;\r\n        font-weight: bold;\r\n}\r\n\r\n\r\n/*****************************************/\r\n/*   C A M P O S   F O R M U L A R I O   */\r\n/*****************************************/\r\n.form_field {\r\n        display: flex;\r\n        width: 100%;\r\n        box-sizing: border-box;\r\n        margin: 0.5em 0;\r\n}\r\n\r\n.form_field_label {\r\n        justify-content: flex-end;\r\n        display: flex;\r\n        align-items: center;\r\n        box-sizing: border-box;\r\n        width: 50%;\r\n}\r\n\r\n.form_field_label_multiple {\r\n        align-items: start;\r\n        justify-content: flex-end;\r\n        display: flex;\r\n        box-sizing: border-box;\r\n        width: 50%;\r\n        padding: 3px;\r\n        font-weight: bold;\r\n        margin: 0.3em 0;\r\n}\r\n\r\n.form_field_label label {\r\n        font-weight: bold;\r\n        display: block;\r\n        padding: 3px;\r\n}\r\n\r\n\r\n.form_field_value {\r\n        align-items: center;\r\n        justify-content: flex-start;\r\n        box-sizing: border-box;\r\n        width: 50%;\r\n        padding: 6px 3px;\r\n        min-height: 30px;\r\n}\r\n\r\n.form_field_value ul {\r\n        margin: 0.15em 0;\r\n        padding: 0px;\r\n        width: 100%;\r\n}\r\n\r\n.form_field_value li {\r\n        list-style: none;\r\n        overflow: hidden;\r\n        padding-bottom: 10px;\r\n        align-items: center;\r\n}\r\n\r\n.form_text {\r\n        clear: both;\r\n        margin: 10px 20px 10px 20px;\r\n        padding: 0px;\r\n        text-align: center;\r\n        font-weight:bold;\r\n        width:100%;\r\n}\r\n\r\n.form_text A,  {\r\n        text-decoration: none;\r\n        display: inline;\r\n        color: #2b2b2b;\r\n}\r\n\r\n.form_text A:hover {\r\n        color:#087021;\r\n        text-decoration: underline;\r\n}\r\n\r\n.select_multiple {\r\n        height: 105px;\r\n        width: 500px;\r\n}\r\n\r\n\r\n/*******************************************/\r\n/*      B   U   S   C   A   D   O   R      */\r\n/*******************************************/\r\n.buscador {\r\n        font-family: 'Noto Sans', Arial, Helvetica, sans-serif !important;\r\n        border: #ccc 1px solid;\r\n        border-radius: 3px !important;\r\n        box-shadow: 1px 1px 8px #ccc !important;\r\n        -moz-border-radius: 3px !important;\r\n        -webkit-border-radius: 3px !important;\r\n        -moz-box-shadow: 1px 1px 8px #ccc !important;\r\n        -webkit-box-shadow: #ccc 1px 1px 8px !important;\r\n        padding: 15px;\r\n        margin: 15px;\r\n        font-size: 14px !important;\r\n}\r\n\r\n.buscador_contenido {\r\n        height: 40px;\r\n        text-align: center;\r\n        align-items: center;\r\n        display: flex;\r\n        justify-content: center;\r\n}\r\n\r\n.resultados_busqueda {\r\n        margin: 15px;\r\n}\r\n\r\n/*******************************************/\r\n/*                                         */\r\n/*      L   I   S   T   A   D   O   S      */\r\n/*                                         */\r\n/*******************************************/\r\n\r\n.ancho1 {\r\n        width: 100%;\r\n}\r\n.ancho2 {\r\n        width: 50%;\r\n}\r\n.ancho3 {\r\n        width: 33%;\r\n}\r\n.ancho4 {\r\n        width: 25%;\r\n}\r\n.ancho5 {\r\n        width: 20%;\r\n}\r\n.ancho7 {\r\n        width: 15%;\r\n}\r\n\r\n.capa_oculta {\r\n        display: none;\r\n}\r\n\r\n.listado {\r\n        width: 100%;\r\n        font-weight: normal !important;\r\n        margin: 15px 0px 15px 0px;\r\n}\r\n\r\n.listado .cabecera {\r\n        color: #000000;\r\n        font-weight: bold;\r\n        font-size: 18px;\r\n        font-family: 'Noto Sans', Arial, Helvetica, sans-serif;\r\n        height: 30px;\r\n        width: 100%;\r\n        text-align: left;\r\n        height: 1%;\r\n        overflow: hidden;\r\n        align-items: center;\r\n        display: flex;\r\n}\r\n\r\n\r\n.listado .fila_impar select, .listado .fila_par select {\r\n        width: 200px;\r\n}\r\n\r\n.listado .campo {\r\n        display: block;\r\n        float: left;\r\n        padding:0px;\r\n        height: 1%;\r\n        overflow: hidden;\r\n        word-wrap: break-word;\r\n}\r\n\r\n.listado .fila_impar, .listado .fila_par, .listado .fila_seleccionada {\r\n        clear: both;\r\n        height: 1%;\r\n        min-height: 40px;\r\n        overflow: hidden;\r\n        padding: 0px;\r\n        align-items: center;\r\n        display: flex;\r\n}\r\n\r\n.listado .fila_impar {\r\n        background-color: #ffffff;\r\n}\r\n\r\n.listado .fila_par {\r\n        background-color: #e9e9e9;\r\n}\r\n\r\n.listado .fila_seleccionada {\r\n        background-color: #f9f4d9;\r\n}\r\n\r\n.listado .fila_detalle, .listado .fila_detalle_seleccionado {\r\n        clear: both;\r\n        background-color: #fdfbf0;\r\n        padding: 10px !important;\r\n        height:1%; \r\n        overflow:hidden;\r\n}\r\n\r\n.listado .fila_detalle {\r\n        display: none;\r\n}\r\n\r\n/***********************************/\r\n/*      I   C   O   N   O   S      */\r\n/***********************************/\r\n.listado .cabecera .icono, .listado .fila_impar .icono, .listado .fila_par .icono,  .listado .fila_seleccionada .icono {\r\n        float: right;\r\n        width: 110px;\r\n        text-align: center;\r\n        padding: 5px 1px;\r\n}\r\n\r\n.listado .cabecera .icono_permisos, .listado .fila_impar .icono_permisos, .listado .fila_par .icono_permisos {\r\n        float: right;\r\n        width: 100px;\r\n        text-align: center;\r\n}\r\n\r\n.listado .cabecera .icono_recursos, .listado .fila_impar .icono_recursos, .listado .fila_par .icono_recursos {\r\n        float: right;\r\n        width: 300px;\r\n        text-align: center;\r\n}\r\n\r\n\r\n/*********************************/\r\n/*   L I S T A D O S   M E N U   */\r\n/*********************************/\r\n.listados_menu {\r\n        padding: 0px;\r\n        height: 1%;\r\n        overflow: hidden;\r\n        float:left;\r\n        margin:10px;\r\n        background: #f0f0f0;\r\n        border: 1px solid #efefef;\r\n        min-height: 250px;\r\n}\r\n\r\n.listados_menu h2 {\r\n        margin: 10px;\r\n        text-align: left;\r\n        border-bottom: 0px;\r\n}\r\n\r\n.listados_menu ul {\r\n        list-style: none;\r\n        padding: 0px 10px;\r\n        display: inline-grid;\r\n}\r\n\r\n.listados_menu li {\r\n        height: 30px;\r\n}\r\n\r\n\r\n/*******************************************/\r\n/*      A D M D E L   P E R M I S O S      */\r\n/*******************************************/\r\n.admdel_permisos {\r\n        padding: 0px;\r\n        height: 1%;\r\n        overflow: hidden;\r\n        float:left;\r\n        margin:10px;\r\n        width:100%;\r\n}\r\n\r\n.admdel_permisos ul {\r\n        list-style: none;\r\n        padding: 0px 10px;\r\n        display: flex;\r\n        flex-wrap: wrap;\r\n}\r\n\r\n.admdel_permisos li {\r\n        width: 200px;\r\n}\r\n\r\n/************************************************************/\r\n/*   S   I   N      C   L   A   S   I   F   I   C   A   R   */\r\n/************************************************************/\r\nfieldset {\r\n        display: flex;\r\n        flex-direction: column;\r\n        align-items: stretch;\r\n        flex-wrap: nowrap;\r\n        padding: 1em;\r\n        border: 1px solid #EEE;\r\n        margin-inline: auto;\r\n        width: 100%;\r\n        box-sizing: border-box;\r\n        table-layout: fixed;\r\n}\r\n\r\nh2, h3 {\r\n        font-weight: normal;\r\n        height: 22px;\r\n        line-height: 22px;\r\n        padding: 0px;\r\n        font-family: 'Noto Sans', Arial, Helvetica, sans-serif;\r\n        border-bottom: #ccc 1px solid;\r\n}\r\n\r\nh2 {\r\n    font-size: 24px !important;\r\n    margin: 2em 0 0 0;        \r\n}\r\n\r\nh3 {\r\n    font-size: 20px !important;\r\n    margin: 1em 0 0 0;        \r\n}\r\n\r\nmain {\r\n        flex: auto;\r\n        overflow: auto; \r\n        height: 100%;\r\n}\r\n\r\n.botones {\r\n        display: flex;\r\n        justify-content: center;\r\n        align-items: center;\r\n        padding-top:5px;\r\n        margin-top:5px;\r\n        clear:both;\r\n}\r\n\r\n.botones A {\r\n        font-size: 1.4rem !important;\r\n        height: 30px !important;\r\n}\r\n\r\n#datos_usuario {\r\n        width: 100%;\r\n        box-sizing: border-box;\r\n        padding-bottom: 5px;\r\n}\r\n\r\n#datos_usuario .card_header {\r\n        display: flex;\r\n        justify-content: left;\r\n}\r\n\r\n.li_delete {\r\n        display: flex;\r\n        justify-content: left;\r\n        align-items: center;\r\n        /*background-color: #ff0000;*/\r\n}\r\n\r\n.miga_contenedor {\r\n        display: flex;\r\n        align-items: center;\r\n        width: 100%;\r\n        margin: 16px;\r\n        height: 30px;\r\n        color: #9e5f00;\r\n        font-family: 'Noto Sans',sans-serif;\r\n}\r\n\r\n.miga_contenedor a {\r\n        line-height: 1.5;\r\n        border-bottom: 2px solid #9e5f00;\r\n        font-weight: bold;\r\n}\r\n\r\n.paginacion {\r\n        width: 100%;\r\n        margin: 20px 0px;\r\n        color: #9e5f00;\r\n        font-family: 'Noto Sans',sans-serif;\r\n}\r\n\r\n.paginacion a {\r\n        line-height: 1.5;\r\n        border-bottom: 2px solid #9e5f00;\r\n        font-weight: bold;\r\n}\r\n\r\n#vista_datos {\r\n        display: flex;\r\n        flex-direction: column;\r\n        width: 100%;\r\n        box-sizing: border-box;\r\n}\r\n\r\n\r\n"
