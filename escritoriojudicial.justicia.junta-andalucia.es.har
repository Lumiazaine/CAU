            "mimeType": "text/css",
            "text": "/* Reset de la css */\r\n@import url('reset.css');\r\n\r\n/* CSS */\r\n* {\r\n\tfont-family: Arial, Helvetica, sans-serif;\r\n\tcolor:#585858;\r\n\tfont-size: 100%;\r\n}\r\nbody {\r\n\tmargin: 0;\r\n\tfont-family: Arial, Helvetica, sans-serif;\r\n\tfont-size: 1.2em; /* 1em = a 10px */\r\n\tbackground: #586440;\t\r\n}\r\n\r\n/* DiseÃ¯Â¿Â½o de elementos comunes */\r\na {\r\n\ttext-decoration: none;\r\n\tcolor: #325b00;\r\n}\r\na:hover {\r\n\ttext-decoration: underline;\r\n}\r\n\r\nh2 {\r\n\tfont-weight: bold;\r\n\tcolor: #325b00;\r\n\tfont-size: 1.6em;\r\n\tborder-bottom: 3px solid #afacb3;\r\n\tline-height: 1.5em;\r\n\toverflow: hidden;\r\n}\r\nh2 a.icon_ir {\r\n\tfont-size: 0.9em;\r\n\tfont-weight: bold;\r\n\tbackground: url(../img/icon_lateral.gif) no-repeat 0 9px;\r\n\tfloat: right;\r\n\tpadding: 0 5px 0 8px;\r\n}\r\nh3 {\r\n\tfont-weight: bold;\r\n}\r\nfieldset h3 {\r\n\tmargin-top:0;\r\n\tborder-bottom: 1px solid #CACACD;\r\n\tpadding-bottom: 0.2em;\r\n\tmargin-bottom:1.2em;\r\n}\r\n#contenido .listado h3.icon_manual {\r\n\tbackground: url(../img/icon_manual.gif) no-repeat 1px 0;\r\n\tpadding-left: 22px;\t\r\n}\r\n#contenido .listado h3.icon_alerta {\r\n\tbackground: url(../img/icon_alerta.gif) no-repeat 0 0;\r\n\tpadding-left: 22px;\t\r\n}\r\n#contenido .listado h3.icon_noticia {\r\n\tbackground: url(../img/icon_noticia.gif) no-repeat 0 0;\r\n\tpadding-left: 22px;\t\r\n}\r\nimg {\r\n\tborder: 0\r\n}\r\nul  {\r\n\tlist-style: none;\r\n\tmargin: 0;\r\n\tpadding: 0;\r\n}\r\nhr {\r\n\tbackground: #e5e4e6;\r\n\tcolor: #e5e4e6;\r\n\tmargin: 16px 0;\r\n\theight: 3px;\r\n}\r\nfieldset hr {\r\n\tmargin: 8px 0 16px;\r\n}\r\n\r\n/* Estilos generales */\r\n.negrita {\r\n\tfont-weight:bold;\r\n}\r\n.centrado {\r\n\ttext-align: center;\r\n}\r\n.ultimo {\r\n\tborder-right: none;\r\n}\r\n.no_visible {\r\n\tdisplay: none;\r\n}\r\n.error {\r\n\tmargin:16px;\r\n}\r\n.error li {\r\n\tcolor: #d20000;\r\n\tfont-size: 1.2em;\r\n\tfont-weight: bold;\r\n\tmargin: 12px 0;\r\n\tlist-style: inside disc;\r\n}\r\ntextarea.errorValidacion{\r\n\tborder: 1px solid red !important;\r\n}\r\ninput[type=radio].errorValidacion,\r\ninput[type=checkbox].errorValidacion\r\n{\r\n\toutline: 1px solid red;\r\n}\r\ndiv.aviso {\r\n\tbackground: #fff0f2 url(../img/icon_aviso.gif) no-repeat 8px 14px;\r\n\tpadding: 5px 10px 5px 30px;\r\n\tmargin: 10px 0 0;\r\n\tborder-bottom: 3px solid #e87f7f;\r\n}\r\ndiv.aviso p {\r\n\tcolor: #d20000;\r\n}\r\n\t\r\n/* Accesibilidad */\r\n#anclajes {\r\n\tdisplay: none;\r\n}\r\n\r\n/* DiseÃ¯Â¿Â½o del contenido */\r\n.fondo {\r\n\tbackground: url(../img/bg_fondo.gif) repeat-y center 0;\r\n}\r\n#cuerpo {\r\n\twidth: 97%;\r\n\tmargin: 0 auto;\r\n}\r\n\r\n/* Cabecera */ \r\n#cabecera {\r\n\tbackground: #73865e url(../img/cabecera_fondo.gif) repeat-x 0 -1px;\r\n\toverflow: hidden;\r\n\theight: 172px;\r\n}\r\n.cabecera_fondo {\r\n\tbackground: url(../img/bg_cabecera.jpg) no-repeat top right;\r\n\toverflow: hidden;\r\n}\r\nh1.logo_junta {\r\n\tfloat: left;\r\n   padding: 48px 33px 40px 36px;\r\n   background: url(../img/h1_bg.gif) no-repeat;\r\n}\r\nh1.aplicacion {\r\n\tbackground: url(../img/logo_aplicacion.png) no-repeat;\r\n\tfloat: left;\r\n\theight: 74px;\r\n   margin: 65px 0 0;\r\n   width: 290px;\r\n}\r\nh1 span {\r\n\tdisplay:none;\r\n}\r\n#cabecera .menu {\r\n\tfloat:right;\r\n\tmargin: 143px 16px 0 0;\r\n\tpadding: 5px;\r\n\tbackground: #97a486;\r\n\tborder-left: 1px solid #d8ddd2;\r\n\tborder-top: 1px solid #d8ddd2;\r\n\toverflow:hidden;\r\n}\r\n#cabecera .menu li {\r\n\tfloat: left;\r\n\tmargin: 0 4px;\r\n}\r\n#cabecera .menu li a {\r\n\theight: 19px;\r\n\twidth: 20px;\r\n\tdisplay: block;\r\n\ttext-indent: -9999px;\r\n}\r\n#cabecera .menu li a.ayuda {\r\n\tbackground: url(../img/menu_ayuda.gif) no-repeat;\r\n}\r\n#cabecera .menu li a.noticias {\r\n\tbackground: url(../img/menu_noticias.gif) no-repeat;\r\n}\r\n#cabecera .menu li a.enlaces {\r\n\tbackground: url(../img/menu_enlaces.gif) no-repeat;\r\n}\r\n#cabecera .menu li a.cerrar {\r\n\tbackground: url(../img/menu_cerrar.gif) no-repeat;\r\n}\r\n\r\n/* Menu superior */ \r\n#menu_superior {\r\n\tbackground: url(../img/bg_menusuperior.gif) repeat-x;\r\n\theight: 23px;\r\n\toverflow: hidden;\r\n\tposition: relative;\r\n\tz-index:3;\r\n\ttop:0;\r\n\tleft: -0.7em;\r\n\tpadding:0 0.4em 0 0.9em;\r\n\twidth: 100%;\r\n\tborder-bottom: 3px solid #3b4c28;\r\n}\r\n#menu_superior p {\r\n\tfont-weight: bold;\r\n\tfont-size: 1.2em;\r\n}\r\n#menu_superior li {\r\n\tcolor: #3b4c28;\r\n\tfont-size: 1.2em;\r\n\tfloat: left;\r\n\tline-height: 2em;\r\n   margin: 0 10px;\r\n}\r\n#menu_superior li.fecha {\r\n\tfloat: right;\r\n}\t\r\n#menu_superior li a {\r\n\tfont-size: 1em;\r\n\tcolor: #3b4c28;\r\n\ttext-decoration: none;\r\n}\r\n\r\n#menu_superior li a span span{\r\n\tfont-size: 12px;\r\n\tcolor: #3b4c28;\r\n\ttext-decoration: none;\r\n}\r\n\r\n#menu_superior .usuario a {\r\n\tfont-weight: bold;\r\n\tbackground: url(../img/icon_usuario.gif) no-repeat;\r\n\tpadding-left: 17px;\r\n}\r\n#menu_superior a:hover {\r\n\ttext-decoration: underline;\r\n}\r\n#menu_superior .opcion a {\r\n\tbackground: url(../img/icon_abajo.gif) no-repeat right 6px;\r\n\tpadding-right: 12px;\r\n}\r\n\r\n/* Contenedor */\r\n#contenedor {\r\n\toverflow: hidden;\r\n\theight: 1%;\r\n\tbackground: #fff url(../img/bg_contenedor.gif) repeat-y top left;\t\r\n}\r\n\r\n/* Menu lateral */ \r\n#lateral_izquierdo {\r\n\tfloat:left;\r\n\twidth: 180px;\r\n\tpadding: 24px 10px 20px 30px;\r\n}\r\n#lateral_izquierdo h2 {\r\n\tborder-bottom: 3px solid #49631c;\r\n\tfont-size: 2em;\r\n\tfont-weight: bold;\r\n\tcolor: #495b35;\r\n\tmargin-bottom: 3px;\r\n}\r\n#lateral_izquierdo ul.menu li {\r\n\tborder-bottom: 3px solid #fff;\r\n}\r\n#lateral_izquierdo ul.menu li a {\r\n\tfont-weight: bold;\r\n\tpadding: 6px 4px 4px 7px;\r\n\ttext-decoration: none;\r\n\tdisplay: block;\r\n\tfont-size: 1.2em;\r\n\tline-height: 1.4em;\r\n\tbackground: url(../img/icon_lateral.gif) no-repeat 0 11px;\r\n}\r\n#lateral_izquierdo ul.menu li a:hover {\r\n\tbackground: #556442;\r\n\tcolor: #fff;\r\n}\r\n\r\n/* Menu derecho */ \r\n#lateral_derecho {\r\n\tfloat:right;\r\n\twidth: 246px;\r\n\tpadding: 24px 10px 0 0;\r\n}\r\n#lateral_derecho img {\r\n\tmargin-top: 2px;\r\n}\r\n\r\n/* Pie */ \r\n#pie {\r\n\tbackground: #43552d;\r\n\toverflow: hidden;\r\n}\r\n#pie p {\r\n\tcolor:#fff;\r\n\tfont-weight: bold;\r\n\tmargin: 0;\r\n\tfloat: left;\r\n\tpadding: 20px 0;\r\n\ttext-transform: uppercase;\r\n}\r\n#pie .izquierda {\r\n\tfloat: left;\r\n\tfont-weight: normal;\r\n\twidth: 220px;\r\n\tbackground: #586440;\r\n\tfont-size: 1.1em;\r\n}\r\n#pie .derecha {\r\n\tfloat: right;\r\n\tfont-size: 1.2em;\r\n\tpadding-bottom: 0;\r\n}\r\n\r\n/* Contenido */ \r\n#contenido {\r\n\tmargin: 0 260px 0 230px;\r\n\tpadding: 5px 10px 20px 10px;\r\n\tmin-height: 300px;\r\n}\r\n#contenido ul.listado, #contenido ul.listado_noticias {\r\n\tmargin: 16px 0;\r\n}\r\n#contenido ul.listado li, #contenido ul.listado_noticias li {\r\n\tmargin: 16px 0;\r\n}\r\n#contenido ul.listado li {\r\n\tborder-bottom: 3px solid #E5E4E6;\r\n}\r\n#contenido ul.listado ul {\r\n\tmargin: 0 0 0 32px;\r\n}\r\n#contenido ul.listado li li {\r\n\tborder-bottom: 0;\r\n\tlist-style: disc inside;\r\n\tcolor: #929c85;\r\n\tmargin: 8px 0;\r\n\tfont-size: 1.2em;\r\n}\r\n#contenido ul.listado li li a {\r\n\tfont-size: 1em;\r\n}\r\n#contenido p {\r\n\tfont-size:1.2em;\r\n\tline-height: 1.4em;\r\n\tmargin: 10px 0;\r\n}\r\n#contenido .listado h3,\r\n#contenido ul.listado_noticias h3 {\r\n\tfont-size:1.3em;\r\n\tline-height: 1.4em;\r\n}\r\n#contenido .listado a,\r\n#contenido ul.listado_noticias a {\r\n\tfont-size:1.2em;\r\n\tline-height: 1.4em;\r\n}\r\n#contenido .listado span.fecha, #contenido .listado_noticias span.fecha {\r\n\tfont-size: 1em;\r\n\tfont-weight:bold;\r\n}\r\n#contenido .listado h3 {\r\n\tbackground: url(../img/icon_flecha.gif) no-repeat 0 4px;\r\n\tpadding-left: 14px;\r\n\tcolor: #325B00;\r\n\tfont-size: 1.3em;\r\n}\r\n#contenido .listado_noticias h3 {\r\n\tbackground: url(../img/icon_flecha.gif) no-repeat 0 6px;\r\n\tpadding-left: 14px;\r\n}\r\n\r\n/* Formularios */\r\n#contenedor fieldset {\r\n\tmargin: 16px 0;\r\n\toverflow: hidden;\r\n}\r\n#contenedor legend {\r\n\tfont-weight:bold;\r\n\tmargin:0 0 16px 0;\r\n\tpadding: 0;\r\n\tcolor: #325b00;\r\n\tfont-size: 1.2em;\r\n\ttext-transform: uppercase;\r\n}\r\n#contenedor form label, #contenedor form input, #contenedor form select {\r\n\tcolor: #585858;\r\n\tfont-size: 1.2em;\r\n}\r\n\r\n\r\n#contenedor form input, #contenedor form select, #contenedor form textarea {\r\n\twidth: 45%;\r\n\tmargin: 0 0 8px;\r\n}\r\n\r\n#contenedor form label {\r\n\t/*font-weight: bold;*/\r\n\tfloat: left;\r\n\twidth: 30%;\r\n\tmax-width: 300px;\r\n\tline-height: 1.4em;\r\n\tcolor: #3b4c28;\r\n\tpadding: 4px 10px 4px 0;\r\n}\r\n#contenido  .labelResaltado {\r\n\tfont-weight: bold;\r\n\r\n}\r\n\r\n\r\n#contenedor form input, #contenedor form select, #contenedor form textarea {\r\n\t/*background:#fff;*/\r\n\tborder:1px solid #586440;\r\n\tpadding: 2px;\r\n}\r\n\r\n.labelUsuario {\r\n\tfont-weight: bold;\r\n\tfloat: left;\r\n\twidth: 20%;\r\n\tmax-width: 300px;\r\n\tline-height: 1.4em;\r\n\tcolor: #3b4c28;\r\n\tpadding: 4px 10px 4px 0;\r\n\tcolor: #585858;\r\n\tfont-size: 1.2em;\r\n}\r\n\r\n.inputUsuario {\r\n\tbackground:#fff;\r\n\tborder:1px solid #586440;\r\n\tpadding: 2px;\r\n\twidth: 45%;\r\n\tmargin: 0 0 8px;\r\n\tcolor: #585858;\r\n\tfont-size: 1.2em;\r\n}\r\n.inputUsuarioCorto {\r\n\tbackground:#fff;\r\n\tborder:1px solid #586440;\r\n\tpadding: 2px;\r\n\twidth: 22%;\r\n\tmargin: 0 0 8px;\r\n\tcolor: #585858;\r\n\tfont-size: 1.2em;\r\n}\r\n\r\n#contenedor form input.radio, #contenedor form input.check {\r\n\twidth: 16px;\r\n\tfloat: left;\r\n\tmargin: 4px 4px 4px 0;\r\n\tborder: 0;\r\n}\r\n#contenedor form input.radio:first-child{\r\n\tmargin: 4px 4px 4px 1px;\r\n}\r\n#contenedor form label.auto {\r\n\tfont-weight: bold;\r\n\twidth: auto;\r\n\twhite-space: nowrap;\r\n}\r\n#contenedor form textarea {\r\n\tfont-size: 1.2em;\r\n\theight: 90px;\r\n}\r\n#contenedor form select {\r\n\twidth: 46%;\r\n}\r\n#contenedor form input.corto {\r\n\twidth: 22%;\r\n}\r\n\r\n#contenedor form select.corto {\r\n\twidth: 23%;\r\n}\r\n#accesoVerificadorBtn, #accesoCertificadoBtn, \r\n#contenedor input.boton, #contenedor .botonera input {\r\n\tpadding: 2px 16px;\r\n\tfont-weight:bold;\r\n\tcursor: pointer;\r\n\twidth: auto;\r\n\tbackground:#fff url(../img/bg_boton.gif) repeat-x bottom right;\r\n\tborder:1px solid #586440;\r\n\tfont-size: 1.2em;\r\n\tcolor: #3b4c28;\r\n \tmargin: 4px;\r\n}\r\n\r\n\r\n#contenedor .botonera input {\r\n\r\n}\r\n#contenedor .fila_form {\r\n\tmargin: 4px 0;\r\n\toverflow: hidden;\r\n}\r\n#contenedor .botonera {\r\n\ttext-align: center;\r\n\tmargin: 4px 0;\r\n\toverflow: hidden;\r\n}\r\n#contenedor .botonera.borde {\r\n\tborder-top: 3px solid #e5e4e6;\r\n\tpadding: 4px 0;\r\n}\r\n#contenedor .login .botonera {\r\n\tmargin: 8px 0;\r\n}\r\n#contenedor .login .botonera.certificado {\r\n\tmargin-top: 26px;\r\n}\r\n\r\n/* Login */\r\n#lateral_derecho .login fieldset {\r\n\tpadding: 8px 10px;\r\n}\r\n#lateral_derecho .login legend {\r\n\tdisplay:none;\r\n}\r\n#lateral_derecho .login label {\r\n\tfont-weight: bold;\r\n\ttext-align: right;\r\n\twidth: 110px;\r\n\tfloat: left;\r\n\tpadding: 2px 10px 2px 0;\r\n}\r\n#lateral_derecho .login input {\r\n\twidth: 100px;\r\n\tmargin: 0;\r\n}\r\n#lateral_derecho .login input.boton {\r\n\twidth: auto;\r\n\tfloat: right;\r\n}\r\n#lateral_derecho .login fieldset {\r\n\tbackground:#eaedeb url(../img/bg_login.gif) no-repeat;\r\n\tmargin: 0 0 10px;\r\n\toverflow: hidden;\r\n\theight: 131px;\r\n}\r\n#lateral_derecho .login h2 {\r\n\tbackground:#586440 url(../img/h2_login.gif) no-repeat;\r\n\tcolor: #fff;\r\n\tborder-bottom-color: #fff;\r\n\tpadding: 2px 60px 2px 8px;\r\n\tfont-size: 2em;\r\n\tfont-weight: normal;\r\n}\r\n\r\n/* Tabla */\r\n#contenido .tabla {\r\n\tmargin: 16px 0;\r\n\tborder:1px solid #929c85;\r\n\twidth: 100%;\r\n}\r\n#contenido .tabla th {\r\n\tbackground:#586440 url(../img/bg_th.gif) 0 -2px repeat-x;\r\n\tcolor: #fff;\r\n\tfont-weight: bold;\r\n\tpadding: 4px;\r\n\ttext-align: left;\r\n\tline-height: 1.6em;\r\n\tfont-size: 1.2em;\r\n}\r\n#contenido .tabla td {\r\n\tpadding: 6px;\r\n\tfont-size: 1.2em;\r\n}\r\n#contenido .tabla td a {\r\n\tfont-size: 1em;\r\n}\r\n.filapar {\r\n\tbackground: #eaedeb;\r\n}\r\nth.icono {\r\n\twidth: 10%;\r\n}\r\nth.corto {\r\n\twidth: 20%;\r\n}\r\n\r\n/* Detalle listas */\r\n#contenido dl {\r\n\toverflow: hidden;\r\n\tmargin-left: 1.6em;\r\n}\r\n#contenido dd {\r\n\tfloat:left;\r\n\tcolor:#325b00;\r\n\tmargin-bottom: 0.3em;\r\n\tmargin-left: 1em;\r\n\tfont-weight: bold;\r\n\twidth: 64%;\r\n}\r\n#contenido dt {\r\n\tfloat:left;\r\n\tmargin-bottom: 0.3em;\r\n\twidth: 30%;\r\n}\r\n#contenido dl.listado_busqueda dt {\r\n\twidth:24%;\r\n}\r\n#contenido dl.listado_busqueda dd {\r\n\twidth:70%;\r\n}\r\n\r\n/* Paginacion */\r\n#contenido .paginacion ul {\r\n\tmargin:0;\r\n\toverflow: hidden;\r\n\theight: 1%;\r\n}\r\n#contenido .paginacion li {\r\n\tfloat: left;\r\n\tpadding: 0 0.5em;\r\n\tmargin: 0;\r\n\tcolor:#545454;;\r\n}\r\n.justificado{\r\n\ttext-align: justify;\r\n    text-justify: inter-word;\r\n}\r\n#contenedor form .fila_form .no-float\r\n{\r\n\tfloat:none;\r\n\tmargin: 4px 4px 4px 1px;\r\n}"
