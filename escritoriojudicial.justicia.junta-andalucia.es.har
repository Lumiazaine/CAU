          "content": {
            "size": 12536,
            "mimeType": "text/html",
            "compression": -66,
            "text": "<!DOCTYPE HTML PUBLIC \"-//W3C//DTD HTML 4.01 Transitional//EN\" \"http://www.w3.org/TR/html4/loose.dtd\">\r\n\r\n\r\n\r\n<html>\r\n<head>\r\n\t<title>Escritorio Virtual</title>\r\n\r\n\t<link href=\"/Escritorio/css/estilos.css\" rel=\"stylesheet\" type=\"text/css\"/>\r\n\t<!--[if IE 6]>\r\n\t<link href=\"/Escritorio/css/estilosIE6.css\" rel=\"stylesheet\" type=\"text/css\"/>\r\n\t<![endif]-->\r\n\t<!--[if IE 7]>\r\n\t<link href=\"/Escritorio/css/estilosIE7.css\" rel=\"stylesheet\" type=\"text/css\" />\r\n\t<![endif]-->\r\n\t<!--[if IE 8]>\r\n\t<link href=\"/Escritorio/css/estilosIE8.css\" rel=\"stylesheet\" type=\"text/css\" />\r\n\t<![endif]-->\r\n\t<!--[if IE 8]>\r\n\t<link href=\"/Escritorio/css/estilosIE9.css\" rel=\"stylesheet\" type=\"text/css\" />\r\n\t<![endif]-->\r\n\t<link href=\"/Escritorio/img/favicon.ico\" type=\"image/x-icon\" rel=\"shortcut icon\" />\r\n\t\r\n\t<script>\r\n\t\tfunction existeSesion()\r\n\t\t{\r\n\t\t\treturn '1';\r\n\t\t}\r\n\t</script>\r\n</head>\r\n\r\n<body onload=\"actualizaReloj(); \">\r\n\t\r\n\t<div class=\"fondo\">\r\n\t\t<div id=\"cuerpo\">\r\n\t\t\t\r\n\r\n\r\n\r\n\r\n\r\n<div id=\"cabecera\">\r\n  <div class=\"cabecera_fondo\">\r\n \t<ul class=\"menu\">\r\n   \t   <li><a class=\"ayuda\" title=\"Manual usuario\" href=\"javascript:verManualEscritorio()\">Manual usuario</a></li>\r\n       <li><a class=\"noticias\" title=\"Noticias\" href=\"javascript:verNoticias()\">Noticias</a></li>\r\n       <li><a class=\"enlaces\" title=\"Enlaces\" href=\"javascript:verEnlaces()\">Enlaces</a></li>\r\n       \r\n       \t<li><a class=\"cerrar\" title=\"Cerrar sesiÃ³n\" href=\"javascript:cerrarSesion()\">Cerrar sesiÃ³n</a></li>\r\n       \r\n    </ul>\r\n    <hr class=\"no_visible\">\r\n    <h1 class=\"logo_junta\">\r\n       <a title=\"JUNTA DE ANDALUCÃA - ConsejerÃ­a de Turismo, RegeneraciÃ³n, Justicia y AdministraciÃ³n Local\" href='/Escritorio/Inicio.do'>\r\n           <img alt=\"JUNTA DE ANDALUCÃA - ConsejerÃ­a d